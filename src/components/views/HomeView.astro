---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import CaseFileCard from '@/components/CaseFileCard.astro';
import { site } from '@/data/site';
import { getLangFromUrl, useTranslations, localizePath, entryLang, entrySlug } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const en = lang === 'en';

const areas = ['security', 'ai', 'automation', 'cloud'] as const;
const marquee = ['Proxmox', 'Docker', 'Kali Linux', 'Wazuh', 'Splunk', 'n8n', 'Cloudflare', 'Google Cloud', 'AWS', 'Azure', 'Linux', 'Bash', 'Ollama', 'OpenAI', 'GitHub', 'RAG', 'Zero Trust', 'MCP'];
const projects = (await getCollection('work', (entry) => !entry.data.draft && entryLang(entry.id) === lang)).sort((a, b) => a.data.order - b.data.order).slice(0, 3);
const posts = (await getCollection('writing', (entry) => !entry.data.draft && entryLang(entry.id) === lang)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 4);
const fmt = (date: Date) => date.toLocaleDateString(en ? 'en-GB' : 'it-IT', { day: '2-digit', month: 'short', year: 'numeric' });
---

<Base path="/">
  <section class="field-hero">
    <div class="field-shell field-hero__inner">
      <div class="field-hero__meta field-label text-ink">
        <span>{site.role}</span><span>{en ? 'Turin / Italy' : 'Torino / Italia'}</span><span>{en ? 'Security · Cloud · AI' : 'Sicurezza · Cloud · AI'}</span>
      </div>
      <div class="field-stamp">● {en ? 'System status: nominal' : 'Stato sistema: nominale'}</div>
      <h1 class="field-display field-hero__title" aria-label="Systems. Security. Evidence.">
        <span class="reveal-mask"><span style="animation-delay:.08s">SYSTEMS.</span></span>
        <span class="reveal-mask"><span style="animation-delay:.18s">SECURITY.</span></span>
        <span class="reveal-mask"><span class="field-serif" style="animation-delay:.28s">EVIDENCE.</span></span>
      </h1>
      <div class="field-hero__portrait" data-parallax>
        <img src="/paolo.png" alt={`${site.name}, ${site.role}`} width="549" height="552" fetchpriority="high" />
      </div>
      <p class="field-hero__copy anim-rise" style="animation-delay:.42s">{t('home.intro')}</p>
      <div class="field-hero__actions anim-rise" style="animation-delay:.52s">
        <a href={localizePath('/work', lang)} class="signal-button">{t('home.ctaWork')}</a>
        <a href={localizePath('/writing', lang)} class="outline-button">{t('home.ctaWriting')}</a>
      </div>
    </div>
  </section>

  <div class="field-ticker" aria-label={en ? 'Technologies and methods' : 'Tecnologie e metodi'}>
    <div class="field-ticker__track">
      {[...marquee, ...marquee].map((item) => <span><b>●</b>&nbsp;&nbsp;{item}</span>)}
    </div>
  </div>

  {projects.length > 0 && (
    <section class="field-section">
      <div class="field-shell">
        <div class="field-heading" data-reveal>
          <p class="field-label">01 / {en ? 'Selected operations' : 'Operazioni selezionate'}</p>
          <div><h2>{en ? 'Proof over' : 'Prima le'}<br /><span class="field-serif text-signal">{en ? 'promises.' : 'prove.'}</span></h2><p class="mt-5 max-w-xl text-muted">{t('home.featuredSub')}</p></div>
        </div>
        <div class="mt-16" data-reveal>
          {projects.map((project, index) => <CaseFileCard href={localizePath(`/work/${entrySlug(project.id)}`, lang)} title={project.data.title} summary={project.data.summary} category={project.data.category} stack={project.data.stack} index={index + 1} />)}
        </div>
        <a href={localizePath('/work', lang)} class="outline-button mt-8">{t('common.all')} ↗</a>
      </div>
    </section>
  )}

  <section class="field-section">
    <div class="field-shell">
      <div class="field-heading" data-reveal>
        <p class="field-label">02 / {en ? 'Operating range' : 'Campo operativo'}</p>
        <div><h2>{en ? 'Four fields.' : 'Quattro campi.'}<br /><span class="field-serif text-signal">{en ? 'One practice.' : 'Una pratica.'}</span></h2><p class="mt-5 max-w-xl text-muted">{t('home.areasSub')}</p></div>
      </div>
      <div class="field-areas" data-reveal>
        {areas.map((area, index) => (
          <article class="field-area"><h3>{t(`area.${area}.t` as any)}</h3><p>{t(`area.${area}.d` as any)}</p><span class="field-area__index">0{index + 1}</span></article>
        ))}
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="field-section">
      <div class="field-shell grid gap-12 lg:grid-cols-[1fr_2fr]">
        <div data-reveal><p class="field-label">03 / Field notes</p><h2 class="mt-5 text-[clamp(3.5rem,7vw,6.5rem)] leading-[.82] tracking-[-.075em]">{en ? 'Recent' : 'Note'}<br /><span class="field-serif text-signal">{en ? 'findings.' : 'recenti.'}</span></h2></div>
        <div data-reveal>
          {posts.map((post) => (
            <a href={localizePath(`/writing/${entrySlug(post.id)}`, lang)} class="archive-row"><time class="font-mono text-[10px] uppercase">{fmt(post.data.pubDate)}</time><span class="font-display text-lg font-semibold tracking-[-.035em]">{post.data.title}</span><span class="font-mono text-[10px] uppercase">↗</span></a>
          ))}
          <a href={localizePath('/writing', lang)} class="outline-button mt-8">{t('common.all')} ↗</a>
        </div>
      </div>
    </section>
  )}
</Base>
