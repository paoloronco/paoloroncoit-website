---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import CaseFileCard from '@/components/CaseFileCard.astro';
import Terminal from '@/components/Terminal.astro';
import SectionHead from '@/components/SectionHead.astro';
import SocialLinks from '@/components/SocialLinks.astro';
import StackGraph from '@/components/StackGraph.astro';
import { site } from '@/data/site';
import { getLangFromUrl, useTranslations, localizePath, entryLang, entrySlug } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const areas = [
  { key: 'security', color: 'var(--color-cat-security)' },
  { key: 'ai', color: 'var(--color-cat-ai)' },
  { key: 'automation', color: 'var(--color-cat-automation)' },
  { key: 'cloud', color: 'var(--color-cat-cloud)' },
] as const;

// Icone (stroke, currentColor) per le card delle aree
const icons: Record<string, string> = {
  security: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg>',
  ai: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="7" width="10" height="10" rx="2"/><path d="M9.5 2v3M14.5 2v3M9.5 19v3M14.5 19v3M2 9.5h3M2 14.5h3M19 9.5h3M19 14.5h3"/></svg>',
  automation: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="6" height="6" rx="1.5"/><rect x="15" y="15" width="6" height="6" rx="1.5"/><path d="M9 6h6a3 3 0 0 1 3 3v6"/></svg>',
  cloud: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M7 18h10a4 4 0 0 0 .5-7.97A6 6 0 0 0 5.5 9.2 3.5 3.5 0 0 0 7 18z"/></svg>',
};

const marquee = ['Proxmox', 'Docker', 'Kali Linux', 'Wazuh', 'Splunk', 'n8n', 'Cloudflare', 'Google Cloud', 'AWS', 'Azure', 'Oracle Cloud (OCI)', 'Linux', 'Bash', 'Ollama', 'vLLM', 'OpenAI', 'GitHub', 'Vercel', 'Wiz', 'RAG', 'Zero Trust', 'MCP'];
const stack = ['Proxmox', 'Docker', 'Kali Linux', 'Wazuh', 'Splunk', 'n8n', 'Cloudflare', 'Google Cloud', 'Linux', 'Bash', 'Ollama', 'OpenAI', 'GitHub'];

const projects = (await getCollection('work', (e) => !e.data.draft && entryLang(e.id) === lang))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const posts = (await getCollection('writing', (e) => !e.data.draft && entryLang(e.id) === lang))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const fmt = (d: Date) =>
  d.toLocaleDateString(lang === 'en' ? 'en-GB' : 'it-IT', { day: '2-digit', month: 'short', year: 'numeric' });
---

<Base path="/">
  <!-- ============ HERO ============ -->
  <section class="relative overflow-hidden border-b border-ink-600/60">
    <div class="hero-fx" aria-hidden="true"></div>
    <div class="home-hero-shell relative z-10 mx-auto max-w-5xl px-5 pt-8 sm:pt-24">
      <div class="home-hero-grid grid grid-cols-1 items-center gap-0 sm:grid-cols-[1fr_0.9fr] sm:gap-6">
        <div class="home-hero-copy relative z-20 -mt-12 pb-2 sm:mt-0">
          <p class="kicker anim-rise text-accent" style="animation-delay:.1s">{site.role}</p>
          <h1 class="mt-3 text-5xl font-semibold leading-[1.02] tracking-tight text-text sm:text-7xl">
            <span class="reveal-mask"><span style="animation-delay:.18s">Paolo</span></span><br />
            <span class="reveal-mask"><span class="text-accent" style="animation-delay:.28s">Ronco</span></span>
          </h1>
          <p class="anim-rise mt-6 max-w-md text-base leading-relaxed text-text-dim" style="animation-delay:.42s">{t('home.intro')}</p>
          <div class="anim-rise mt-7 flex flex-wrap items-center gap-3" style="animation-delay:.54s">
            <a href={localizePath('/projects', lang)} class="btn-shine rounded-md bg-accent px-4 py-2.5 text-sm font-medium text-ink-900 shadow-lg shadow-accent/20 transition-all hover:-translate-y-0.5 hover:shadow-accent/40">
              {t('home.ctaWork')}
            </a>
            <a href={localizePath('/writing', lang)} class="rounded-md border border-ink-500 px-4 py-2.5 text-sm font-medium text-text-dim transition-all hover:-translate-y-0.5 hover:border-accent hover:text-text">
              {t('home.ctaWriting')}
            </a>
            <div class="ml-1 flex items-center gap-1.5">
              <SocialLinks />
            </div>
          </div>
        </div>

        <div class="hero-portrait home-hero-portrait anim-rise order-first -mx-5 flex h-[17.5rem] items-end justify-end overflow-hidden sm:order-none sm:mx-0 sm:h-auto sm:overflow-visible sm:justify-end" style="animation-delay:.34s">
          <div class="photo-frame">
            <img src="/paolo.png" alt={`${site.name}, ${site.role}`} width="549" height="552" fetchpriority="high"
              class="relative z-10 w-[20.5rem] max-w-full translate-x-7 object-contain object-bottom drop-shadow-2xl sm:w-[24rem] sm:translate-x-0 lg:w-[27rem]" />
          </div>
        </div>
      </div>

      <!-- TERMINALE -->
      <div class="home-hero-terminal anim-rise mt-10 pb-16 sm:mt-14 sm:pb-20" style="animation-delay:.64s">
        <Terminal />
      </div>
    </div>

    <!-- marquee competenze -->
    <div class="marquee relative z-10 border-t border-ink-600/60 py-3">
      <div class="marquee__track">
        {[...marquee, ...marquee].map((m) => (
          <span class="flex items-center whitespace-nowrap px-5 font-mono text-xs uppercase tracking-widest text-muted">
            {m}<span class="ml-5 text-accent/50">/</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ AREE ============ -->
  <section class="mx-auto max-w-5xl px-5 py-24">
    <SectionHead eyebrow={t('home.whatIDo')} title={t('home.areasTitle')} accent={t('home.areasAccent')} sub={t('home.areasSub')} />
    <nav class="mt-8 flex flex-wrap justify-center gap-3" aria-label={t('home.areasAccent')}>
      <a href={localizePath('/skills', lang)} class="rounded-md border border-ink-500 px-4 py-2.5 text-sm font-medium text-text-dim transition-all hover:-translate-y-0.5 hover:border-accent hover:text-text">
        {t('nav.skills')}
      </a>
      <a href={localizePath('/projects', lang)} class="rounded-md border border-ink-500 px-4 py-2.5 text-sm font-medium text-text-dim transition-all hover:-translate-y-0.5 hover:border-accent hover:text-text">
        {t('nav.projects')}
      </a>
      <a href={localizePath('/writing', lang)} class="rounded-md border border-ink-500 px-4 py-2.5 text-sm font-medium text-text-dim transition-all hover:-translate-y-0.5 hover:border-accent hover:text-text">
        {t('nav.writing')}
      </a>
    </nav>
    <div class="mt-12 grid gap-4 sm:grid-cols-2">
      {areas.map((a, i) => (
        <article
          data-reveal
          style={`--c:${a.color};--i:${i}`}
          class="glow-card group overflow-hidden rounded-2xl border border-ink-600 p-6 sm:p-7"
        >
          <div class="flex items-start justify-between">
            <span class="glow-card__icon" set:html={icons[a.key]} />
            <span class="font-display text-2xl font-semibold tabular-nums text-ink-500 transition-colors group-hover:text-[var(--c)]">0{i + 1}</span>
          </div>
          <h3 class="mt-5 text-xl font-semibold tracking-tight text-text transition-colors group-hover:text-[var(--c)]">
            {t(`area.${a.key}.t` as any)}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{t(`area.${a.key}.d` as any)}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ============ STACK ============ -->
  <section class="section-glow border-y border-ink-600/60 py-24">
    <div class="mx-auto max-w-5xl px-5">
      <SectionHead eyebrow={t('home.stackEyebrow')} title={t('home.stackTitle')} accent={t('home.stackAccent')} sub={t('home.stackSub')} />
      <!-- desktop: costellazione animata · mobile: chip leggibili -->
      <div class="mt-10 hidden md:block" data-reveal>
        <StackGraph />
      </div>
      <div class="mt-12 flex flex-wrap justify-center gap-2.5 md:hidden" data-reveal>
        {stack.map((s) => (
          <span class="stack-chip rounded-lg px-3.5 py-2 font-mono text-sm text-text-dim">{s}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PROGETTI ============ -->
  {projects.length > 0 && (
    <section class="mx-auto max-w-5xl px-5 py-24">
      <SectionHead eyebrow={t('home.featuredEyebrow')} title={t('home.featured')} accent={t('home.featuredAccent')} sub={t('home.featuredSub')} />
      <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-3">
        {projects.map((p, i) => (
          <div data-reveal style={`--i:${i + 1}`}>
            <CaseFileCard href={localizePath(`/projects/${entrySlug(p.id)}`, lang)} title={p.data.title} summary={p.data.summary} category={p.data.category} stack={p.data.stack} index={i + 1} />
          </div>
        ))}
      </div>
      <div class="mt-8 text-center" data-reveal>
        <a href={localizePath('/projects', lang)} class="link-underline text-sm text-muted hover:text-accent">{t('common.all')}</a>
      </div>
    </section>
  )}

  <!-- ============ ARTICOLI ============ -->
  {posts.length > 0 && (
    <section class="mx-auto max-w-5xl px-5 py-24">
      <SectionHead eyebrow={t('home.recentEyebrow')} title={t('home.recent')} accent={t('home.recentAccent')} sub={t('home.recentSub')} />
      <ul class="mx-auto mt-12 max-w-3xl divide-y divide-ink-600/70 border-y border-ink-600/70">
        {posts.map((p, i) => (
          <li data-reveal style={`--i:${i + 1}`}>
            <a href={localizePath(`/writing/${entrySlug(p.id)}`, lang)} class="group flex flex-col gap-1 py-5 sm:flex-row sm:items-baseline sm:gap-5">
              <time class="font-mono text-xs text-muted sm:w-24 sm:shrink-0">{fmt(p.data.pubDate)}</time>
              <div>
                <span class="font-medium text-text-dim transition-colors group-hover:text-accent">{p.data.title}</span>
                <p class="mt-0.5 text-sm text-muted">{p.data.description}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-8 text-center" data-reveal>
        <a href={localizePath('/writing', lang)} class="link-underline text-sm text-muted hover:text-accent">{t('common.all')}</a>
      </div>
    </section>
  )}
</Base>
