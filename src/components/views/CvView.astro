---
import Base from '@/layouts/Base.astro';
import CmdPath from '@/components/CmdPath.astro';
import { resolveCert } from '@/data/certs';
import { enterpriseSecurityArea } from '@/data/site';
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const en = lang === 'en';

const experience: { period: string; role: string; sub?: string; org: string }[] = [
  { period: en ? 'Nov 2024 — present' : 'Nov 2024 — presente', role: 'Cyber Security Analyst', sub: enterpriseSecurityArea, org: 'Deloitte Consulting' },
  { period: en ? 'Jul 2024 — Oct 2024' : 'Lug 2024 — Ott 2024', role: 'Junior System Administrator', org: en ? 'Dylog s.p.a. — Turin' : 'Dylog s.p.a. — Torino' },
  { period: en ? 'Jan 2018 — Feb 2018' : 'Gen 2018 — Feb 2018', role: en ? 'IT Services / CED' : 'Servizi IT / CED', org: 'Comune di Grugliasco' },
  { period: en ? 'Jan 2018 — Feb 2018' : 'Gen 2018 — Feb 2018', role: 'Accounting Services / IT Services', org: 'FIM-CISL Torino e Canavese' },
  { period: en ? 'Mar 2017 — Apr 2017' : 'Mar 2017 — Apr 2017', role: 'IT Services', org: 'PerMicro s.p.a. — Gruppo BNP Paribas' },
];

const education = [
  { type: t('edu.corso'), title: 'CyberSecurity', org: en ? 'Istituto Volta — Milan' : 'Istituto Volta — Milano' },
  { type: t('edu.laurea'), title: 'Scienze della Comunicazione, Digital Entertainment and Marketing', org: 'Università eCampus — Novedrate (CO)' },
  { type: t('edu.diploma'), title: 'Amministrazione, Finanza e Marketing', org: 'IIS Gobetti Marchesini Casale Arduino — Torino' },
];

const certs = [
  'CompTIA Security+', 'CompTIA AI Essentials', 'Splunk Core Certified User',
  'Google Cybersecurity Professional Certificate', 'Google IT Support', 'AWS Cloud Essentials',
  'Google Cloud Generative AI Leader', 'Google Cloud Skill Boost',
  'Cisco NetAcad — Get Connected',
  'Cisco NetAcad — Introduction to CyberSecurity',
  'Cisco NetAcad — NGD Linux Unhatched',
  'Intel Network Academy',
].map(resolveCert);

const languages = [
  { lang: t('lang.it'), level: t('level.native') },
  { lang: t('lang.en'), level: t('level.advanced') },
  { lang: t('lang.es'), level: t('level.basic') },
];
---
<Base title="CV" description={t('cv.skillsCardDesc')} path="/cv">
  <section class="field-shell max-w-5xl pt-14 pb-20 sm:pt-20">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <CmdPath cmd="cat" arg="resume.md" />
        <h1 class="field-display anim-rise mt-6 text-[clamp(5rem,12vw,10rem)]" style="animation-delay:.12s">CV<span class="text-signal">.</span></h1>
      </div>
      <a href="/cv.pdf" class="outline-button">{t('cv.downloadPdf')}</a>
    </div>

    <h2 class="kicker mt-12 mb-6">{t('cv.experience')}</h2>
    <div class="relative">
      <span class="absolute left-1/2 top-2 hidden h-[calc(100%-1rem)] w-px -translate-x-1/2 bg-ink-600 sm:block" aria-hidden="true"></span>
      <ol>
        {experience.map((e, i) => {
          const right = i % 2 === 1;
          return (
            <li
              data-reveal={right ? 'right' : 'left'}
              style={`--i:${i}`}
              class:list={['relative mb-4 sm:mb-7 sm:w-1/2', right ? 'sm:ml-auto sm:pl-9' : 'sm:pr-9 sm:text-right']}
            >
              <span
                class="tl-dot absolute top-5 hidden h-3.5 w-3.5 rounded-full border-2 border-ink-900 bg-accent sm:block"
                style={right ? 'left:-7px' : 'right:-7px'}
                aria-hidden="true"
              ></span>
              <div class="border border-ink bg-transparent p-5 transition-colors hover:bg-signal hover:text-white">
                <p class="font-mono text-xs text-accent">{e.period}</p>
                <p class="mt-1.5 font-medium leading-snug text-text">{e.role}</p>
                {e.sub && <p class="text-sm leading-snug text-text-dim">{e.sub}</p>}
                <p class="mt-1 text-sm text-muted">{e.org}</p>
              </div>
            </li>
          );
        })}
      </ol>
    </div>

    <h2 class="kicker mt-10 mb-4">{t('cv.skills')}</h2>
    <a href={localizePath('/skills', lang)} class="group flex items-center justify-between rounded-card border border-ink-600 bg-ink-800/40 p-5 transition-colors hover:border-accent">
      <div>
        <p class="font-medium text-text">{t('cv.skillsCard')}</p>
        <p class="mt-1 text-sm text-muted">{t('cv.skillsCardDesc')}</p>
      </div>
      <span class="ml-4 shrink-0 font-mono text-sm text-accent transition-transform group-hover:translate-x-0.5">/skills →</span>
    </a>

    <div class="mt-12 mb-4 flex items-baseline justify-between">
      <h2 class="kicker">{t('cv.certs')}</h2>
      <span class="font-mono text-xs text-muted">{certs.length}</span>
    </div>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      {certs.map((c, i) => (
        <div
          data-reveal
          style={`--c:${c.color};--i:${Math.min(i, 6)}`}
          class="group flex items-center gap-4 rounded-xl border border-ink-600 bg-ink-800/40 p-4 transition-all hover:-translate-y-0.5 hover:border-[var(--c)] hover:bg-ink-800"
        >
          {c.logo ? (
            <span class="flex h-16 w-[5.5rem] shrink-0 items-center justify-center rounded-xl bg-paper px-3 py-2.5 shadow-md shadow-black/30 ring-1 ring-black/5">
              <img src={c.logo} alt={c.issuer} width="80" height="48" loading="lazy" class="max-h-11 max-w-full object-contain" />
            </span>
          ) : (
            <span class="flex h-16 w-[5.5rem] shrink-0 items-center justify-center rounded-xl bg-paper text-lg font-bold shadow-md shadow-black/30" style={`color:${c.color}`}>{c.initials}</span>
          )}
          <div class="min-w-0">
            <p class="font-display text-base font-semibold leading-snug text-text">{c.name}</p>
            <p class="mt-1 text-xs uppercase tracking-wide text-muted">{c.issuer}</p>
          </div>
        </div>
      ))}
    </div>

    <h2 class="kicker mt-12 mb-4">{t('cv.education')}</h2>
    <div class="grid grid-cols-1 gap-3">
      {education.map((e) => (
        <div class="rounded-card border border-ink-600 bg-ink-800/40 p-5 transition-colors hover:border-accent/50">
          <span class="kicker text-accent">{e.type}</span>
          <p class="mt-2 font-medium leading-snug text-text">{e.title}</p>
          <p class="mt-1 text-sm text-muted">{e.org}</p>
        </div>
      ))}
    </div>

    <h2 class="kicker mt-12 mb-4">{t('cv.languages')}</h2>
    <div class="flex flex-wrap gap-2">
      {languages.map((l) => (
        <span class="rounded-full border border-ink-600 bg-ink-800/40 px-4 py-2 text-sm text-text">{l.lang} <span class="text-muted">· {l.level}</span></span>
      ))}
    </div>
  </section>
</Base>
