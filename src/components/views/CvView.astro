---
import Base from '@/layouts/Base.astro';
import CmdPath from '@/components/CmdPath.astro';
import { resolveCert } from '@/data/certs';
import { enterpriseSecurityArea } from '@/data/site';
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const en = lang === 'en';

const experience: { period: string; role: string; sub?: string; org: string }[] = [
  { period: en ? 'Nov 2024 — present' : 'Nov 2024 — presente', role: 'Cyber Security Analyst', sub: enterpriseSecurityArea, org: 'Deloitte Consulting' },
  { period: en ? 'Jul 2024 — Oct 2024' : 'Lug 2024 — Ott 2024', role: 'Junior System Administrator', org: en ? 'Dylog s.p.a. — Turin' : 'Dylog s.p.a. — Torino' },
  { period: en ? 'Jan 2018 — Feb 2018' : 'Gen 2018 — Feb 2018', role: en ? 'IT Services / CED' : 'Servizi IT / CED', org: 'Comune di Grugliasco' },
  { period: en ? 'Jan 2018 — Feb 2018' : 'Gen 2018 — Feb 2018', role: 'Accounting Services / IT Services', org: 'FIM-CISL Torino e Canavese' },
  { period: en ? 'Mar 2017 — Apr 2017' : 'Mar 2017 — Apr 2017', role: 'IT Services', org: 'PerMicro s.p.a. — Gruppo BNP Paribas' },
];

const education = [
  { type: t('edu.corso'), title: 'CyberSecurity', org: en ? 'Istituto Volta — Milan' : 'Istituto Volta — Milano' },
  { type: t('edu.laurea'), title: 'Scienze della Comunicazione, Digital Entertainment and Marketing', org: 'Università eCampus — Novedrate (CO)' },
  { type: t('edu.diploma'), title: 'Amministrazione, Finanza e Marketing', org: 'IIS Gobetti Marchesini Casale Arduino — Torino' },
];

const certs = [
  'CompTIA Security+', 'CompTIA AI Essentials', 'Splunk Core Certified User',
  'Google Cybersecurity Professional Certificate', 'Google IT Support', 'AWS Cloud Essentials',
  'Google Cloud Digital Leader', 'Google Cloud Generative AI Leader', 'Google Cloud Associate Cloud Engineer',
  'Cisco NetAcad — Get Connected',
  'Cisco NetAcad — Introduction to CyberSecurity',
  'Cisco NetAcad — NDG Linux Unchained',
  'Intel Network Academy',
].map((cert) => resolveCert(cert));

const languages = [
  { lang: t('lang.it'), level: t('level.native') },
  { lang: t('lang.en'), level: t('level.advanced') },
  { lang: t('lang.es'), level: t('level.basic') },
];

const certificatesPath = en ? '/en/certifications' : '/certificati';
const cvPdfPath = en ? '/cv-en.pdf' : '/cv-it.pdf';
const issuerBadgeStyle = (_color: string) =>
  'border-color:color-mix(in oklab, var(--color-ink-500) 68%, transparent);background:color-mix(in oklab, var(--color-ink-700) 58%, transparent);color:var(--color-text-dim);';
const logoFrameStyle = (_color: string) =>
  'box-shadow:0 0 0 1px color-mix(in oklab, var(--color-ink-500) 58%, transparent);';
---
<Base title="CV" description={t('cv.skillsCardDesc')} path="/cv">
  <section class="mx-auto max-w-3xl px-5 pt-16 pb-16">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <CmdPath cmd="cat" arg="resume.md" />
        <h1 class="anim-rise mt-3 text-4xl font-semibold tracking-tight text-text" style="animation-delay:.12s">CV</h1>
      </div>
      <a href={cvPdfPath} download class="rounded-md border border-ink-500 px-3 py-2 text-sm text-text-dim hover:border-accent hover:text-text">
        {t('cv.downloadPdf')}
      </a>
    </div>

    <h2 class="kicker mt-12 mb-6">{t('cv.experience')}</h2>
    <div class="relative">
      <span class="absolute left-1/2 top-2 hidden h-[calc(100%-1rem)] w-px -translate-x-1/2 bg-ink-600 sm:block" aria-hidden="true"></span>
      <ol>
        {experience.map((e, i) => {
          const right = i % 2 === 1;
          return (
            <li
              data-reveal={right ? 'right' : 'left'}
              style={`--i:${i}`}
              class:list={['relative mb-4 sm:mb-7 sm:w-1/2', right ? 'sm:ml-auto sm:pl-9' : 'sm:pr-9 sm:text-right']}
            >
              <span
                class="tl-dot absolute top-5 hidden h-3.5 w-3.5 rounded-full border-2 border-ink-900 bg-accent sm:block"
                style={right ? 'left:-7px' : 'right:-7px'}
                aria-hidden="true"
              ></span>
              <div class="rounded-xl border border-ink-600 bg-ink-800/40 p-5 transition-all hover:-translate-y-0.5 hover:border-accent/60">
                <p class="font-mono text-xs text-accent">{e.period}</p>
                <p class="mt-1.5 font-medium leading-snug text-text">{e.role}</p>
                {e.sub && <p class="text-sm leading-snug text-text-dim">{e.sub}</p>}
                <p class="mt-1 text-sm text-muted">{e.org}</p>
              </div>
            </li>
          );
        })}
      </ol>
    </div>

    <a
      href={localizePath('/skills', lang)}
      data-reveal
      class="group mt-10 flex flex-col gap-3 rounded-xl border border-ink-600 bg-ink-800/45 p-4 transition-all hover:-translate-y-0.5 hover:border-accent/65 hover:bg-ink-800/70 sm:flex-row sm:items-center sm:justify-between"
    >
      <div class="min-w-0">
        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
          <h2 class="kicker text-accent">{t('cv.skills')}</h2>
          <p class="font-display text-base font-semibold leading-snug text-text">{t('cv.skillsCard')}</p>
        </div>
        <p class="mt-1.5 text-sm leading-relaxed text-muted">{t('cv.skillsCardDesc')}</p>
      </div>
      <span class="inline-flex shrink-0 items-center justify-center self-start rounded-md border border-accent/35 bg-accent/10 px-3 py-2 font-mono text-xs font-semibold text-accent transition-all group-hover:translate-x-0.5 group-hover:border-accent group-hover:bg-accent/15 group-hover:text-text sm:self-center">
        /skills →
      </span>
    </a>

    <div class="mt-12 mb-5 flex flex-wrap items-center justify-between gap-3">
      <h2 class="kicker">{t('cv.certs')}</h2>
      <a href={certificatesPath} class="inline-flex rounded-md border border-accent/40 bg-accent/10 px-3 py-2 font-mono text-xs font-semibold text-accent transition-colors hover:border-accent hover:bg-accent/15 hover:text-text">
        {en ? 'all documents' : 'tutti i documenti'} →
      </a>
    </div>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      {certs.map((c, i) => (
        <div
          data-reveal
          style={`--c:${c.color};--i:${Math.min(i, 6)}`}
          class="group flex items-start justify-between gap-3 rounded-xl border border-ink-600 bg-ink-800/65 p-4 shadow-lg shadow-black/10 transition-all hover:-translate-y-0.5 hover:border-[var(--c)] hover:bg-ink-800 hover:shadow-2xl hover:shadow-black/20"
        >
          <div class="min-w-0">
            <p class="inline-flex max-w-full rounded-md border px-2 py-1 font-mono text-[11px] font-semibold uppercase tracking-wide" style={issuerBadgeStyle(c.color)}>{c.issuer}</p>
            <p class="mt-2 font-display text-lg font-semibold leading-snug text-text">{c.name}</p>
          </div>
          {c.logo ? (
            <span class="flex h-12 w-20 shrink-0 items-center justify-center rounded-lg bg-paper/90 px-1.5 py-2 opacity-60 ring-1 ring-black/5 transition-opacity group-hover:opacity-75" style={logoFrameStyle(c.color)}>
              <img
                src={c.logo}
                alt={c.issuer}
                width="96"
                height="48"
                loading="lazy"
                class:list={[
                  'max-h-9 max-w-full object-contain',
                  c.issuer === 'CompTIA' && 'scale-105',
                ]}
              />
            </span>
          ) : (
            <span class="flex h-12 w-16 shrink-0 items-center justify-center rounded-lg bg-paper/90 text-sm font-bold opacity-60 transition-opacity group-hover:opacity-75" style={`color:${c.color};${logoFrameStyle(c.color)}`}>{c.initials}</span>
          )}
        </div>
      ))}
    </div>

    <h2 class="kicker mt-12 mb-4">{t('cv.education')}</h2>
    <div class="grid grid-cols-1 gap-3">
      {education.map((e) => (
        <div class="rounded-card border border-ink-600 bg-ink-800/40 p-5 transition-colors hover:border-accent/50">
          <span class="kicker text-accent">{e.type}</span>
          <p class="mt-2 font-medium leading-snug text-text">{e.title}</p>
          <p class="mt-1 text-sm text-muted">{e.org}</p>
        </div>
      ))}
    </div>

    <h2 class="kicker mt-12 mb-4">{t('cv.languages')}</h2>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      {languages.map((l, i) => (
        <div
          data-reveal
          style={`--i:${i}`}
          class="rounded-xl border border-ink-600 bg-ink-800/65 p-4 shadow-lg shadow-black/10 transition-colors hover:border-accent/55"
        >
          <p class="font-display text-xl font-semibold leading-tight text-text">{l.lang}</p>
          <p class="mt-2 inline-flex rounded-md border border-accent/35 bg-accent/10 px-2 py-1 font-mono text-[11px] font-semibold uppercase tracking-wide text-accent">{l.level}</p>
        </div>
      ))}
    </div>
  </section>
</Base>
