---
import Base from '@/layouts/Base.astro';
import CmdPath from '@/components/CmdPath.astro';
import { resolveCert } from '@/data/certs';
import cvContent from '@/data/cv-content.json';
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const en = lang === 'en';

type Localized = string | { it?: string; en?: string };
const pick = (value: Localized | undefined) => {
  if (!value) return '';
  if (typeof value === 'string') return value;
  return value[lang] ?? value.it ?? value.en ?? '';
};

const experience = cvContent.experience.map((item) => ({
  period: pick(item.period),
  role: pick(item.role),
  sub: pick(item.sub),
  org: pick(item.org),
  description: pick(item.description),
}));

const education = cvContent.education.map((item) => ({
  type: pick(item.type),
  title: pick(item.siteTitle ?? item.title),
  org: pick(item.siteOrg ?? item.org),
}));

const certs = cvContent.certifications
  .filter((cert) => cert.cvPageOrder)
  .sort((a, b) => (a.cvPageOrder ?? 0) - (b.cvPageOrder ?? 0))
  .map((cert) => resolveCert(pick(cert.siteName ?? cert.name), cert.provider));

const languages = cvContent.languages.map((item) => ({
  lang: pick(item.name),
  level: pick(item.level),
}));

const profileSummary = pick(cvContent.profile.summary);
const certificatesPath = en ? '/en/certifications' : '/certificati';
const cvPdfPath = en ? '/cv-en.pdf' : '/cv-it.pdf';
const issuerBadgeStyle = (_color: string) =>
  'border-color:color-mix(in oklab, var(--color-ink-500) 68%, transparent);background:color-mix(in oklab, var(--color-ink-700) 58%, transparent);color:var(--color-text-dim);';
const logoFrameStyle = (_color: string) =>
  'box-shadow:0 0 0 1px color-mix(in oklab, var(--color-ink-500) 58%, transparent);';
---
<Base title="CV" description={t('cv.skillsCardDesc')} path="/cv">
  <section class="lab-page-shell mx-auto max-w-6xl px-5 pt-16 pb-20">
    <div class="lab-page-hero">
      <div class="max-w-3xl">
        <CmdPath cmd="cat" arg="resume.md" />
        <h1 class="anim-rise mt-4 text-5xl font-semibold leading-tight text-text sm:text-6xl" style="animation-delay:.12s">CV</h1>
        <p class="anim-rise mt-4 max-w-2xl text-base leading-relaxed text-text-dim" style="animation-delay:.2s">{profileSummary}</p>
      </div>
      <a href={cvPdfPath} download class="btn-shine inline-flex rounded-md bg-accent px-4 py-2.5 text-sm font-semibold text-ink-900 shadow-lg shadow-accent/20 transition-all hover:-translate-y-0.5 hover:shadow-accent/40">
        {t('cv.downloadPdf')}
      </a>
    </div>

    <section class="lab-page-section">
      <h2 class="kicker mb-6 text-accent">{t('cv.experience')}</h2>
      <ol class="cv-flow">
        {experience.map((e, i) => {
          return (
            <li
              data-reveal
              style={`--i:${i}`}
              class="cv-flow__item"
            >
              <span class="cv-flow__dot" aria-hidden="true"></span>
              <div class="cv-flow__date">{e.period}</div>
              <div class="lab-section-card p-5">
                <p class="font-display text-xl font-semibold leading-tight text-text">{e.role}</p>
                {e.sub && <p class="mt-1 text-sm leading-snug text-text-dim">{e.sub}</p>}
                <p class="mt-1 text-sm text-muted">{e.org}</p>
                {e.description && <p class="mt-3 text-sm leading-relaxed text-muted">{e.description}</p>}
              </div>
            </li>
          );
        })}
      </ol>
    </section>

    <a
      href={localizePath('/skills', lang)}
      data-reveal
      class="lab-section-card group mt-10 flex flex-col gap-3 p-5 transition-all hover:-translate-y-0.5 hover:border-accent/65 sm:flex-row sm:items-center sm:justify-between"
    >
      <div class="min-w-0">
        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
          <h2 class="kicker text-accent">{t('cv.skills')}</h2>
        </div>
        <p class="mt-1.5 text-sm leading-relaxed text-muted">{t('cv.skillsCardDesc')}</p>
      </div>
      <span class="inline-flex shrink-0 items-center justify-center self-start rounded-md border border-accent/35 bg-accent/10 px-3 py-2 font-mono text-xs font-semibold text-accent transition-all group-hover:translate-x-0.5 group-hover:border-accent group-hover:bg-accent/15 group-hover:text-text sm:self-center">
        /skills →
      </span>
    </a>

    <div class="mt-14 mb-5 flex flex-wrap items-center justify-between gap-3">
      <h2 class="kicker">{t('cv.certs')}</h2>
      <a href={certificatesPath} class="inline-flex rounded-md border border-accent/40 bg-accent/10 px-3 py-2 font-mono text-xs font-semibold text-accent transition-colors hover:border-accent hover:bg-accent/15 hover:text-text">
        {en ? 'all documents' : 'tutti i documenti'} →
      </a>
    </div>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {certs.map((c, i) => (
        <div
          data-reveal
          style={`--c:${c.color};--i:${Math.min(i, 6)}`}
          class="lab-section-card group flex items-start justify-between gap-3 p-4 transition-all hover:-translate-y-0.5 hover:border-[var(--c)]"
        >
          <div class="min-w-0">
            <p class="inline-flex max-w-full rounded-md border px-2 py-1 font-mono text-[11px] font-semibold uppercase tracking-wide" style={issuerBadgeStyle(c.color)}>{c.issuer}</p>
            <p class="mt-2 font-display text-lg font-semibold leading-snug text-text">{c.name}</p>
          </div>
          {c.logo ? (
            <span class="flex h-12 w-20 shrink-0 items-center justify-center rounded-lg bg-paper/90 px-1.5 py-2 opacity-60 ring-1 ring-black/5 transition-opacity group-hover:opacity-75" style={logoFrameStyle(c.color)}>
              <img
                src={c.logo}
                alt={c.issuer}
                width="96"
                height="48"
                loading="lazy"
                class:list={[
                  'max-h-9 max-w-full object-contain',
                  c.issuer === 'CompTIA' && 'scale-105',
                ]}
              />
            </span>
          ) : (
            <span class="flex h-12 w-16 shrink-0 items-center justify-center rounded-lg bg-paper/90 text-sm font-bold opacity-60 transition-opacity group-hover:opacity-75" style={`color:${c.color};${logoFrameStyle(c.color)}`}>{c.initials}</span>
          )}
        </div>
      ))}
    </div>

    <h2 class="kicker mt-14 mb-4">{t('cv.education')}</h2>
    <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
      {education.map((e) => (
        <div class="lab-section-card p-5 transition-colors hover:border-accent/50">
          <span class="kicker text-accent">{e.type}</span>
          <p class="mt-2 font-medium leading-snug text-text">{e.title}</p>
          <p class="mt-1 text-sm text-muted">{e.org}</p>
        </div>
      ))}
    </div>

    <h2 class="kicker mt-14 mb-4">{t('cv.languages')}</h2>
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
      {languages.map((l, i) => (
        <div
          data-reveal
          style={`--i:${i}`}
          class="lab-section-card p-4 transition-colors hover:border-accent/55"
        >
          <p class="font-display text-xl font-semibold leading-tight text-text">{l.lang}</p>
          <p class="mt-2 inline-flex rounded-md border border-accent/35 bg-accent/10 px-2 py-1 font-mono text-[11px] font-semibold uppercase tracking-wide text-accent">{l.level}</p>
        </div>
      ))}
    </div>
  </section>
</Base>
