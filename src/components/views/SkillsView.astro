---
import Base from '@/layouts/Base.astro';
import { skillCategories, skillsTagline } from '@/data/skills';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const total = skillCategories.reduce((n, c) => n + c.skills.length, 0);
const slug = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-');
---
<Base title="Skills" description={skillsTagline[lang]} path="/skills">
  <section class="mx-auto max-w-5xl px-5 pt-16 pb-8">
    <p class="kicker text-accent">{t('skills.kicker')} · {total}+ {t('skills.skillUnit')}</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-text sm:text-5xl">Skills</h1>
    <p class="mt-4 max-w-2xl text-text-dim">{skillsTagline[lang]}</p>

    <nav class="mt-8 flex flex-wrap gap-2" aria-label="Skill categories">
      {skillCategories.map((c) => (
        <a href={`#${slug(c.name.en)}`} style={`--c:${c.color}`} class="rounded-full border border-ink-600 px-3 py-1 text-xs text-text-dim transition-colors hover:border-[var(--c)] hover:text-text">
          {c.name[lang]}
        </a>
      ))}
    </nav>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-16">
    {skillCategories.map((cat) => (
      <div data-reveal id={slug(cat.name.en)} style={`--c:${cat.color}`} class="scroll-mt-20 border-t border-ink-600/70 py-10">
        <div class="mb-6 flex items-center gap-3">
          <span class="h-5 w-1.5 rounded-full" style={`background:${cat.color}`}></span>
          <h2 class="text-xl font-semibold text-text">{cat.name[lang]}</h2>
          <span class="font-mono text-xs text-muted">{cat.skills.length}</span>
        </div>

        <div class="grid grid-cols-1 gap-x-8 gap-y-5 md:grid-cols-2">
          {cat.skills.map((s) => (
            <div>
              <div class="flex items-center justify-between gap-2">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-medium text-text">{s.name}</span>
                  {s.hands && (
                    <span class="rounded px-1.5 py-0.5 font-mono text-[9px] uppercase tracking-wider" style={`color:${cat.color};background:color-mix(in oklab, ${cat.color} 16%, transparent)`}>{t('skills.handsOn')}</span>
                  )}
                </div>
                <span class="font-mono text-xs tabular-nums text-muted">{s.level}%</span>
              </div>
              <div class="mt-1.5 h-1.5 overflow-hidden rounded-full bg-ink-600">
                <span class="block h-full rounded-full" style={`width:${s.level}%;background:${cat.color}`}></span>
              </div>
              {s.desc && <p class="mt-1.5 text-xs leading-relaxed text-muted">{s.desc[lang]}</p>}
              {s.tools && (
                <div class="mt-2 flex flex-wrap gap-1">
                  {s.tools.map((tool) => <span class="rounded border border-ink-600 px-1.5 py-0.5 font-mono text-[10px] text-text-dim">{tool}</span>)}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}

    <p class="mt-6 font-mono text-xs text-muted">{t('skills.source')}: <a href="https://skills.paoloronco.it" class="text-accent hover:underline">skills.paoloronco.it</a></p>
  </section>
</Base>
