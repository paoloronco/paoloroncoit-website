---
import { resolveCert } from '@/data/certs';
import { enterpriseSecurityArea } from '@/data/site';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const en = lang === 'en';
const printMode = Astro.url.searchParams.get('mode') === 'print';

const sectionTitle = en ? 'Work Experience' : 'Esperienza';
const certTitle = en ? 'Certifications' : 'Certificazioni';
const skillsTitle = en ? 'Main Skills' : 'Competenze principali';
const educationTitle = en ? 'Education' : 'Formazione';
const languagesTitle = en ? 'Languages' : 'Lingue';

const experience = [
  {
    period: en ? 'Nov 2024 — present' : 'Nov 2024 — presente',
    role: 'Cyber Security Analyst',
    sub: enterpriseSecurityArea,
    org: 'Deloitte Consulting',
  },
  {
    period: en ? 'Jul 2024 — Oct 2024' : 'Lug 2024 — Ott 2024',
    role: 'Junior System Administrator',
    org: en ? 'Dylog s.p.a. — Turin' : 'Dylog s.p.a. — Torino',
  },
  {
    period: en ? 'Jan 2018 — Feb 2018' : 'Gen 2018 — Feb 2018',
    role: en ? 'IT Services / CED' : 'Servizi IT / CED',
    org: 'Comune di Grugliasco',
  },
  {
    period: en ? 'Jan 2018 — Feb 2018' : 'Gen 2018 — Feb 2018',
    role: 'Accounting Services / IT Services',
    org: 'FIM-CISL Torino e Canavese',
  },
  {
    period: en ? 'Mar 2017 — Apr 2017' : 'Mar 2017 — Apr 2017',
    role: 'IT Services',
    org: en ? 'PerMicro s.p.a. — BNP Paribas Group' : 'PerMicro s.p.a. — Gruppo BNP Paribas',
  },
];

const education = [
  { type: t('edu.corso'), title: 'CyberSecurity', org: en ? 'Istituto Volta — Milan' : 'Istituto Volta — Milano' },
  { type: t('edu.laurea'), title: 'Scienze della Comunicazione, Digital Entertainment and Marketing', org: 'Università eCampus — Novedrate (CO)' },
  { type: t('edu.diploma'), title: 'Amministrazione, Finanza e Marketing', org: 'IIS Gobetti Marchesini Casale Arduino — Torino' },
];

const certs = [
  'CompTIA Security+',
  'CompTIA AI Essentials',
  'Splunk Core Certified User',
  'Google Cybersecurity Professional Certificate',
  'Google IT Support',
  'AWS Cloud Essentials',
  'Google Cloud Digital Leader',
  'Google Cloud Generative AI Leader',
  'Google Cloud Associate Cloud Engineer',
  'Cisco NetAcad — Get Connected',
  'Cisco NetAcad — Introduction to CyberSecurity',
  'Cisco NetAcad — NDG Linux Unchained',
  'Intel Network Academy',
].map((cert) => resolveCert(cert));

const topSkills = [
  'Cloud Security',
  'SIEM / SOAR',
  'IAM',
  'Zero Trust',
  'Threat & Vulnerability Management',
  'Incident Response',
  'Threat Intelligence',
  'GRC',
];

const supportSkills = [
  'Linux / Proxmox',
  'n8n / Make / GitHub Actions',
  'API Orchestration',
  'Network Architecture',
  'Automation',
  'Monitoring',
  'DevSecOps',
  'Observability',
];

const cloudSkills = [
  'Google Cloud Platform',
  'AWS',
  'Azure',
  'Oracle Cloud Infrastructure',
  'Containers',
  'IaC',
  'CI/CD',
  'AI & MCP',
];

const languages = [
  { lang: t('lang.it'), level: t('level.native') },
  { lang: t('lang.en'), level: t('level.advanced') },
  { lang: t('lang.es'), level: t('level.basic') },
];

const profileSummary = en
  ? 'Profile focused on enterprise cloud security, automation and practical AI implementation. Focus on risk reduction, resilient architectures and operational playbooks.'
  : 'Profilo focalizzato sulla sicurezza cloud enterprise, automazione e applicazione pratica dell’AI, con focus su riduzione del rischio, resilienza e playbook operativi.';

const roleTitle = 'Cyber Security Analyst';
---

<main class={`cv-print-page ${printMode ? 'is-print' : ''}`}>
  <article class="cv-sheet">
    <header class="cv-header">
      <img src="/paolo.png" alt="Paolo Ronco" class="cv-avatar" width="102" height="102" loading="eager" />
      <div class="cv-intro">
        <p class="kicker">CV</p>
        <h1>Paolo Ronco</h1>
        <p class="role">{roleTitle}</p>
        <p class="summary">{profileSummary}</p>
      </div>
      <div class="contact" aria-label="contact">
        <p>paoloronco.it</p>
        <p>info@paoloronco.it</p>
        <p>linkedin.com/in/paolo-ronco</p>
        <p>Torino, Italia</p>
      </div>
    </header>

    <section class="panel-grid">
      <section class="panel">
        <div class="panel-title-wrap">
          <h2>{sectionTitle}</h2>
          <span class="panel-line" aria-hidden="true"></span>
        </div>
        <ul class="timeline" aria-label={sectionTitle}>
          {experience.map((e) => (
            <li class="timeline-item">
              <p class="period">{e.period}</p>
              <div class="timeline-content">
                <p class="title">{e.role}</p>
                {e.sub && <p class="subtle">{e.sub}</p>}
                <p class="muted">{e.org}</p>
              </div>
            </li>
          ))}
        </ul>
      </section>

      <section class="panel panel-slim">
        <div class="panel-title-wrap">
          <h2>{skillsTitle}</h2>
          <span class="panel-line" aria-hidden="true"></span>
        </div>
        <div class="skills-grid">
          <div class="skill-group">
            {topSkills.map((name) => <span>{name}</span>)}
          </div>
          <div class="skill-group">
            {supportSkills.map((name) => <span>{name}</span>)}
          </div>
          <div class="skill-group">
            {cloudSkills.map((name) => <span>{name}</span>)}
          </div>
        </div>
      </section>
    </section>

    <section class="panel-grid panel-grid-bottom">
      <section class="panel">
        <div class="panel-title-wrap">
          <h2>{certTitle}</h2>
          <span class="panel-line" aria-hidden="true"></span>
        </div>
        <ul class="cert-grid">
          {certs.map((c) => (
            <li class="cert-item">
              <p class="issuer">{c.issuer}</p>
              <p class="name">{c.name}</p>
            </li>
          ))}
        </ul>
      </section>

      <section class="panel right-stack">
        <section class="mini">
          <div class="panel-title-wrap">
            <h3>{educationTitle}</h3>
            <span class="panel-line" aria-hidden="true"></span>
          </div>
          <ul class="education">
            {education.map((e) => (
              <li>
                <p class="title">{e.type}</p>
                <p class="name">{e.title}</p>
                <p class="muted">{e.org}</p>
              </li>
            ))}
          </ul>
        </section>

        <section class="mini">
          <div class="panel-title-wrap">
            <h3>{languagesTitle}</h3>
            <span class="panel-line" aria-hidden="true"></span>
          </div>
          <div class="lang-grid">
            {languages.map((l) => (
              <p><span>{l.lang}</span><span>{l.level}</span></p>
            ))}
          </div>
        </section>
      </section>
    </section>
  </article>
</main>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(*)::before,
  :global(*)::after {
    box-sizing: inherit;
  }

  :global(*) {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  :root {
    --cv-text: #0f172a;
    --cv-muted: #475569;
    --cv-line: #c8d3e5;
    --cv-head: #0f172a;
    --cv-soft: #64748b;
    --cv-accent: #3b82f6;
    --cv-bg: #f8fafc;
    --cv-card: #ffffff;
  }

  .cv-print-page {
    margin: 0;
    padding: 7mm;
    background: #f1f5f9;
    color: var(--cv-text);
    min-height: 100vh;
  }

  @page {
    size: A4 portrait;
    margin: 0;
  }

  .cv-sheet {
    width: min(100%, 1000px);
    min-height: calc(297mm - 14mm);
    margin: 0 auto;
    display: grid;
    gap: 3.2mm;
    background: var(--cv-card);
    box-shadow: 0 16px 45px rgba(15, 23, 42, 0.08);
    border: 1px solid #dbe3f0;
    padding: 4.5mm;
    font: 10px / 1.35 Inter, Arial, sans-serif;
  }

  .cv-header {
    display: grid;
    grid-template-columns: 102px 1fr auto;
    gap: 10px;
    align-items: stretch;
    padding: 7px 8px;
    border: 1px solid #1e293b;
    background: linear-gradient(130deg, #0f172a, #14295d 64%);
    color: #e5edff;
    border-radius: 2px;
  }

  .cv-avatar {
    width: 102px;
    height: 102px;
    border-radius: 6px;
    object-fit: cover;
    object-position: center top;
    border: 1px solid rgba(248, 250, 252, 0.45);
    box-shadow: 0 6px 20px rgba(2, 8, 23, 0.28);
    filter: saturate(0.96) contrast(1.03);
  }

  .cv-intro {
    display: grid;
    gap: 3px;
    min-width: 0;
  }

  .kicker {
    margin: 0;
    color: #93c5fd;
    font-size: 8.5px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  h1 {
    margin: 0;
    font-size: 29px;
    line-height: 1;
    letter-spacing: -0.015em;
    color: #ffffff;
  }

  .role {
    margin: 0;
    font-size: 11px;
    color: #bfdbfe;
    font-weight: 600;
    letter-spacing: 0.015em;
  }

  .summary {
    margin: 1px 0 0;
    max-width: 610px;
    font-size: 9.1px;
    line-height: 1.35;
    color: #d8e2ff;
  }

  .contact {
    align-self: end;
    margin: 0;
    display: grid;
    align-content: end;
    text-align: right;
    color: #c7d6ff;
    font-size: 8.8px;
    font-weight: 500;
    border-left: 1px solid rgba(148, 163, 184, 0.45);
    padding-left: 8px;
    line-height: 1.28;
  }

  .contact p {
    margin: 0;
  }

  .panel {
    border: 1px solid var(--cv-line);
    background: #f8fbff;
    padding: 5px 6px;
    min-height: 0;
    display: grid;
    gap: 4px;
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }

  .panel:before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: linear-gradient(to bottom, var(--cv-accent), rgba(15, 23, 42, 0.2));
  }

  h2,
  h3 {
    margin: 0;
    font-size: 9.5px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--cv-soft);
    font-weight: 700;
  }

  h2 {
    display: inline-flex;
    background: linear-gradient(90deg, rgba(37, 99, 235, 0.12), rgba(37, 99, 235, 0));
    width: fit-content;
    padding: 2px 6px;
    border-radius: 2px;
  }

  h3 {
    font-size: 8.8px;
  }

  .panel-title-wrap {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 2px;
  }

  .panel-line {
    height: 1px;
    width: 36px;
    background: color-mix(in oklab, var(--cv-accent) 32%, transparent);
    opacity: 0.75;
  }

  .panel-grid {
    display: grid;
    gap: 3.2mm;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    align-items: start;
  }

  .timeline,
  .cert-grid,
  .education,
  .skills-grid,
  .education,
  .lang-grid {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .timeline {
    display: grid;
    gap: 3.2px;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 4px;
    padding: 2px 0 2px 4px;
    border-top: 1px dashed #e2e8f0;
  }

  .timeline-item:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .period {
    margin: 0;
    color: #1d4ed8;
    font-size: 8.2px;
    font-weight: 700;
    font-family: 'Courier New', monospace;
    line-height: 1.2;
  }

  .timeline-content {
    display: grid;
    gap: 1px;
  }

  .title {
    margin: 0;
    font-size: 9.8px;
    font-weight: 700;
    color: var(--cv-head);
  }

  .subtle,
  .muted {
    margin: 0;
    color: var(--cv-muted);
    font-size: 8.4px;
    line-height: 1.28;
  }

  .cert-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2px 3px;
  }

  .cert-item {
    list-style: none;
    border: 1px solid var(--cv-line);
    border-radius: 2px;
    background: #fff;
    padding: 3px 4px;
    min-height: 20px;
  }

  .issuer {
    margin: 0;
    color: #1d4ed8;
    font-size: 7.4px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  .cert-item .name {
    margin: 1px 0 0;
    color: var(--cv-head);
    font-weight: 600;
    font-size: 8.8px;
    line-height: 1.22;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2.6px;
  }

  .skill-group {
    margin: 0;
    min-width: 0;
    display: grid;
    gap: 2.4px;
  }

  .skill-group span,
  .education li,
  .lang-grid p {
    border: 1px solid var(--cv-line);
    background: #fff;
    padding: 3px 5px;
    line-height: 1.2;
    font-size: 8px;
    color: var(--cv-head);
    font-weight: 500;
  }

  .right-stack {
    display: grid;
    gap: 3px;
  }

  .mini h3 {
    margin-bottom: 2px;
  }

  .education li {
    display: grid;
    gap: 1px;
    border-radius: 2px;
    min-height: 29px;
  }

  .education .name {
    margin: 0;
    color: var(--cv-head);
    font-weight: 600;
    font-size: 9.1px;
    line-height: 1.2;
  }

  .education .muted {
    margin-top: 1px;
  }

  .lang-grid {
    display: grid;
    gap: 2.4px;
    grid-template-columns: 1fr;
  }

  .lang-grid p {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
    color: var(--cv-head);
    font-weight: 600;
    align-items: center;
  }

  .lang-grid span:last-child {
    color: var(--cv-accent);
    font-weight: 700;
    font-size: 8px;
    letter-spacing: 0.01em;
  }

  .timeline-item,
  .cert-item,
  .education li,
  .skill-group span,
  .lang-grid p {
    break-inside: avoid;
    page-break-inside: avoid;
  }

  @media (max-width: 900px) {
    .cv-print-page {
      padding: 7mm;
    }

    .cv-sheet,
    .panel-grid {
      width: 100%;
      grid-template-columns: 1fr;
      gap: 2.9mm;
    }

    .cv-header {
      grid-template-columns: 82px 1fr;
      grid-template-rows: auto auto;
    }

    .contact {
      grid-column: 1 / -1;
      padding-left: 0;
      border-left: 0;
      border-top: 1px solid rgba(148, 163, 184, 0.45);
      padding-top: 4px;
      margin-top: 4px;
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 8px 12px;
    }

    .contact p {
      white-space: nowrap;
    }

    .panel-grid-bottom {
      margin-top: 0;
    }

    .skills-grid,
    .cert-grid,
    .panel-grid {
      grid-template-columns: 1fr;
    }
  }

  @media print {
    :global(body),
    :global(html) {
      margin: 0;
      background: #fff;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .cv-print-page {
      margin: 0;
      padding: 6mm;
      min-height: 0;
      background: #fff;
    }

    @page {
      size: A4 portrait;
      margin: 0;
    }

    .cv-sheet {
      width: calc(210mm - 12mm);
      height: calc(297mm - 12mm);
      min-height: 0;
      max-height: calc(297mm - 12mm);
      overflow: hidden;
      gap: 2.6mm;
      padding: 4mm 4.3mm;
      box-shadow: none;
      border: 1px solid #d7e0f1;
    }

    .cv-header {
      padding: 5px 6px;
    }

    .cv-avatar {
      width: 82px;
      height: 68px;
      border-radius: 4px;
    }

    .cv-sheet,
    .cv-intro,
    .summary {
      font-size: 9px;
    }

    h1 {
      font-size: 25px;
    }

    .summary {
      font-size: 8.5px;
      max-width: 460px;
    }

    h2 {
      font-size: 8.9px;
    }

    .panel {
      gap: 2.8px;
    }

    .timeline-item {
      grid-template-columns: 38px 1fr;
      gap: 3px;
      padding: 1.7px 0 1.7px 4px;
    }

    .timeline,
    .cert-grid,
    .education,
    .skills-grid,
    .lang-grid {
      gap: 2px;
    }

    .title {
      font-size: 9px;
    }

    .subtle,
    .muted {
      font-size: 7.6px;
    }

    .issuer {
      font-size: 7px;
    }

    .cert-item,
    .skill-group span,
    .education li,
    .lang-grid p {
      padding: 2.4px 4px;
      line-height: 1.15;
    }

    .panel-line {
      width: 28px;
    }
  }
</style>

{printMode && <script is:inline>setTimeout(() => window.print(), 30);</script>}
