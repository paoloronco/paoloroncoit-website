---
import Base from '@/layouts/Base.astro';
import CmdPath from '@/components/CmdPath.astro';
import { certificateEntries, type CertificateAsset } from '@/data/certificateAssets';
import { resolveCert, type ResolvedCert } from '@/data/certs';
import { getLangFromUrl, localizePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const en = lang === 'en';

const pageTitle = en ? 'Certifications' : 'Certificati';
const pagePath = en ? '/certifications' : '/certificati';
const subtitle = en
  ? 'Verified certificates, badges and supporting documents collected in one place.'
  : 'Certificazioni, badge e documenti di supporto raccolti in un unico posto.';
const searchLabel = en ? 'Search certifications' : 'Cerca certificazioni';
const searchPlaceholder = en ? 'Search by vendor, skill, certificate or file...' : 'Cerca per ente, competenza, certificazione o file...';
const allLabel = en ? 'All' : 'Tutto';
const emptyTitle = en ? 'No matching documents' : 'Nessun documento trovato';
const emptyText = en
  ? 'Try a vendor, a technology area, or an asset type like PDF or badge.'
  : 'Prova con un ente, un ambito tecnico o un tipo di asset come PDF o badge.';

const fileUrl = (file: string) => `/certificati/${encodeURIComponent(file)}`;
const assetHref = (asset: CertificateAsset) => asset.url ?? (asset.file ? fileUrl(asset.file) : '#');
const assetVerb = (asset: CertificateAsset) => {
  if (asset.type === 'pdf') return en ? 'View PDF' : 'Vedi PDF';
  if (asset.type === 'web') return en ? 'Open badge' : 'Apri badge';
  return en ? 'Open' : 'Apri';
};
const assetTypeLabel = (type: CertificateAsset['type']) => {
  if (type === 'pdf') return 'PDF';
  if (type === 'web') return 'Badge';
  return en ? 'Text' : 'Testo';
};

type ResolvedEntry = {
  title: string;
  cert: ResolvedCert;
  assets: CertificateAsset[];
  credlyUrl?: string;
  search: string;
  assetTypes: CertificateAsset['type'][];
};

const entries: ResolvedEntry[] = certificateEntries.map((entry) => {
  const cert = resolveCert(entry.title, entry.issuer);
  const assets = entry.assets.filter((asset) => asset.type !== 'image');
  const assetTypes = [
    ...new Set([
      ...assets.map((asset) => asset.type),
      ...(entry.credlyUrl ? (['web'] satisfies CertificateAsset['type'][]) : []),
    ]),
  ];
  const search = [
    entry.title,
    entry.issuer,
    cert.name,
    cert.issuer,
    cert.initials,
    entry.credlyUrl ? 'credly badge verified' : '',
    entry.credlyUrl,
    ...assets.flatMap((asset) => [asset.label, asset.type, asset.file, asset.url]),
  ]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();

  return {
    title: entry.title,
    cert,
    assets,
    credlyUrl: entry.credlyUrl,
    search,
    assetTypes,
  };
});

const issuerFilters = [...new Set(entries.map((entry) => entry.cert.issuer).filter((issuer) => issuer !== '—'))].sort((a, b) =>
  a.localeCompare(b)
);
const typeFilters = [...new Set(entries.flatMap((entry) => entry.assetTypes))].sort();
---

<Base title={pageTitle} description={subtitle} path={pagePath}>
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="max-w-3xl">
      <CmdPath cmd="find" arg={en ? '~/certifications -type f' : '~/certificati -type f'} />
      <p class="kicker mt-5 text-accent">{en ? 'Evidence vault' : 'Archivio evidenze'}</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-text sm:text-6xl">{pageTitle}</h1>
      <p class="mt-5 text-base leading-relaxed text-text-dim">{subtitle}</p>
    </div>

    <div class="mt-10 rounded-xl border border-ink-600 bg-ink-800/55 p-4 shadow-2xl shadow-black/20 sm:p-5">
      <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
        <label class="block">
          <span class="sr-only">{searchLabel}</span>
          <span class="relative block">
            <span class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 font-mono text-xs text-accent">/</span>
            <input
              data-cert-search
              type="search"
              autocomplete="off"
              placeholder={searchPlaceholder}
              class="h-12 w-full rounded-lg border border-ink-500 bg-ink-900/70 pl-9 pr-4 text-base text-text outline-none transition-colors placeholder:text-muted focus:border-accent"
            />
          </span>
        </label>

        <div class="flex justify-end">
          <button
            type="button"
            data-clear-search
            class="rounded-md border border-ink-600 px-3 py-2 text-xs font-medium text-text-dim transition-colors hover:border-accent hover:text-text"
          >
            {en ? 'Reset' : 'Reset'}
          </button>
        </div>
      </div>

      <div class="mt-4 flex flex-wrap gap-2" aria-label={en ? 'Certification filters' : 'Filtri certificazioni'}>
        <button
          type="button"
          data-cert-filter="all"
          aria-pressed="true"
          class="cert-filter rounded-md border border-accent/60 bg-accent/15 px-3 py-2 text-xs font-medium text-text transition-colors"
        >
          {allLabel}
        </button>
        {issuerFilters.map((issuer) => (
          <button
            type="button"
            data-cert-filter={issuer.toLowerCase()}
            aria-pressed="false"
            class="cert-filter rounded-md border border-ink-600 bg-ink-900/35 px-3 py-2 text-xs font-medium text-text-dim transition-colors hover:border-accent hover:text-text"
          >
            {issuer}
          </button>
        ))}
        {typeFilters.map((type) => (
          <button
            type="button"
            data-cert-filter={type}
            aria-pressed="false"
            class="cert-filter rounded-md border border-ink-600 bg-ink-900/35 px-3 py-2 text-xs font-medium text-text-dim transition-colors hover:border-accent hover:text-text"
          >
            {assetTypeLabel(type)}
          </button>
        ))}
      </div>
    </div>

    <div data-cert-grid class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
      {entries.map((entry, i) => (
        <article
          data-cert-card
          data-search={entry.search}
          data-issuer={entry.cert.issuer.toLowerCase()}
          data-types={entry.assetTypes.join(' ')}
          style={`--c:${entry.cert.color};--i:${Math.min(i, 8)}`}
          class="cert-card group flex min-h-[18rem] flex-col overflow-hidden rounded-xl border border-ink-600 bg-ink-800/45 transition-all hover:-translate-y-1 hover:border-[var(--c)] hover:bg-ink-800"
        >
          <div class="flex min-h-[12.5rem] flex-col p-5">
            <div class="flex gap-4">
              {entry.cert.logo ? (
                <span class="flex h-16 w-24 shrink-0 items-center justify-center rounded-xl bg-paper px-2 py-2.5 shadow-md shadow-black/30 ring-1 ring-black/5">
                  <img src={entry.cert.logo} alt={entry.cert.issuer} width="88" height="48" loading="lazy" class="max-h-12 max-w-full object-contain" />
                </span>
              ) : (
                <span class="flex h-16 w-24 shrink-0 items-center justify-center rounded-xl bg-paper text-lg font-bold shadow-md shadow-black/30" style={`color:${entry.cert.color}`}>
                  {entry.cert.initials}
                </span>
              )}

              <div class="min-w-0">
                <p class="font-mono text-[11px] uppercase tracking-wide text-muted">{entry.cert.issuer}</p>
                <h2 class="mt-1 font-display text-xl font-semibold leading-tight text-text">{entry.cert.name}</h2>
              </div>
            </div>

            <div class="mt-auto flex h-9 items-end">
              {entry.credlyUrl ? (
                <a
                  href={entry.credlyUrl}
                  target="_blank"
                  rel="noopener"
                  data-credly-link
                  class="inline-flex h-8 items-center gap-2 rounded-md border border-[#f36f21]/55 bg-[#f36f21]/12 px-2.5 text-xs font-semibold text-text transition-colors hover:border-[#f36f21] hover:bg-[#f36f21]/18"
                >
                  <span class="flex h-5 w-5 items-center justify-center rounded-sm bg-[#f36f21] font-display text-[11px] font-bold leading-none text-ink-900">C</span>
                  <span>Credly</span>
                  <span class="font-mono text-[10px] text-[#f36f21]">↗</span>
                </a>
              ) : (
                <span class="h-8" aria-hidden="true"></span>
              )}
            </div>
          </div>

          <div class="mt-auto border-t border-ink-600 bg-ink-900/25 p-4">
            <div class="grid gap-2">
              {entry.assets.map((asset) => (
                <a
                  href={assetHref(asset)}
                  target="_blank"
                  rel="noopener"
                  class="group/link flex items-center justify-between gap-3 rounded-lg border border-ink-600 bg-ink-900/40 px-3 py-3 text-sm text-text-dim transition-colors hover:border-[var(--c)] hover:text-text"
                >
                  <span class="min-w-0 font-medium">{assetVerb(asset)}</span>
                  <span class="shrink-0 font-mono text-xs text-accent transition-transform group-hover/link:translate-x-0.5">↗</span>
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <div data-empty-state hidden class="mt-8 rounded-xl border border-ink-600 bg-ink-800/45 p-8 text-center">
      <p class="font-display text-2xl font-semibold text-text">{emptyTitle}</p>
      <p class="mt-2 text-sm text-muted">{emptyText}</p>
    </div>

    <div class="mt-10">
      <a href={localizePath('/cv', lang)} class="inline-flex rounded-md border border-ink-600 px-3 py-2 text-sm text-text-dim transition-colors hover:border-accent hover:text-text">
        {en ? 'Back to CV' : 'Torna al CV'}
      </a>
    </div>
  </section>

  <script>
    const searchInput = document.querySelector<HTMLInputElement>('[data-cert-search]');
    const clearButton = document.querySelector<HTMLButtonElement>('[data-clear-search]');
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-cert-card]'));
    const filters = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-cert-filter]'));
    const emptyState = document.querySelector<HTMLElement>('[data-empty-state]');
    let activeFilter = 'all';

    const normalize = (value: string) =>
      value
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .trim();

    const matchesFilter = (card: HTMLElement) => {
      if (activeFilter === 'all') return true;
      const issuer = card.dataset.issuer || '';
      const types = card.dataset.types || '';
      return issuer === activeFilter || types.split(' ').includes(activeFilter);
    };

    const setFilterState = () => {
      filters.forEach((filter) => {
        const selected = filter.dataset.certFilter === activeFilter;
        filter.setAttribute('aria-pressed', String(selected));
        filter.classList.toggle('border-accent/60', selected);
        filter.classList.toggle('bg-accent/15', selected);
        filter.classList.toggle('text-text', selected);
        filter.classList.toggle('border-ink-600', !selected);
        filter.classList.toggle('bg-ink-900/35', !selected);
        filter.classList.toggle('text-text-dim', !selected);
      });
    };

    const applyFilters = () => {
      const query = normalize(searchInput?.value || '');
      let visible = 0;

      cards.forEach((card) => {
        const searchable = normalize(card.dataset.search || '');
        const show = matchesFilter(card) && (!query || searchable.includes(query));
        card.hidden = !show;
        if (show) visible += 1;
      });

      if (emptyState) emptyState.hidden = visible !== 0;
    };

    searchInput?.addEventListener('input', applyFilters);
    clearButton?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      activeFilter = 'all';
      setFilterState();
      applyFilters();
      searchInput?.focus();
    });

    filters.forEach((filter) => {
      filter.addEventListener('click', () => {
        activeFilter = filter.dataset.certFilter || 'all';
        setFilterState();
        applyFilters();
      });
    });

    setFilterState();
    applyFilters();
  </script>
</Base>
