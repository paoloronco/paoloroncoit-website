---
import { render, type CollectionEntry } from 'astro:content';
import Base from '@/layouts/Base.astro';
import { getLangFromUrl, useTranslations, localizePath, entrySlug } from '@/i18n/utils';
interface Props { post: CollectionEntry<'writing'> }
const { post } = Astro.props;
const lang = getLangFromUrl(Astro.url); const t = useTranslations(lang); const { Content, headings } = await render(post); const d = post.data;
const fmt = (date: Date) => date.toLocaleDateString(lang === 'en' ? 'en-GB' : 'it-IT', { day: '2-digit', month: 'long', year: 'numeric' });
const toc = headings.filter((heading) => heading.depth === 2); const readMin = Math.max(1, Math.round((post.body?.trim().split(/\s+/).length ?? 0) / 200));
const ld = { '@context': 'https://schema.org', '@type': 'Article', headline: d.title, description: d.description, datePublished: d.pubDate.toISOString(), dateModified: (d.updatedDate ?? d.pubDate).toISOString(), author: { '@type': 'Person', name: 'Paolo Ronco' }, inLanguage: lang };
---
<Base title={d.title} description={d.description} path={`/writing/${entrySlug(post.id)}`}>
  <div class="fixed left-0 top-0 z-40 h-1 w-0 bg-signal" data-progress></div>
  <header class="field-section pt-12"><div class="field-shell"><a href={localizePath('/writing', lang)} class="field-label hover:text-ink">← {t('writing.back')}</a><div class="mt-14 grid gap-8 lg:grid-cols-[1fr_3fr]"><div class="font-mono text-[10px] uppercase leading-6 text-muted"><time>{fmt(d.pubDate)}</time><br />{readMin} {t('writing.minRead')}<br />{d.tags.slice(0, 4).map((tag) => <span class="mr-2 text-signal">#{tag}</span>)}</div><div><h1 class="font-display text-[clamp(3rem,7vw,6.5rem)] font-semibold leading-[.9] tracking-[-.065em]">{d.title}</h1><p class="mt-7 max-w-3xl font-serif text-xl leading-relaxed text-muted italic sm:text-2xl">{d.description}</p></div></div></div></header>
  <div class="field-shell grid gap-12 py-16 lg:grid-cols-[1fr_3fr]">
    <aside class="hidden lg:block"><div class="sticky top-24"><p class="field-label mb-5">{t('writing.toc')}</p>{toc.length > 0 && <ul class="border-t border-ink">{toc.map((heading) => <li><a href={`#${heading.slug}`} class="block border-b border-ink py-3 text-sm text-muted hover:text-signal">{heading.text}</a></li>)}</ul>}</div></aside>
    <article class="prose"><Content /></article>
  </div>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(ld)} />
  <script is:inline data-astro-rerun>(() => { const bar = document.querySelector('[data-progress]'); if (!bar || bar.dataset.ready) return; bar.dataset.ready = '1'; const update = () => { const root = document.documentElement; const max = root.scrollHeight - root.clientHeight; bar.style.width = `${max > 0 ? root.scrollTop / max * 100 : 0}%`; }; document.addEventListener('scroll', update, { passive: true }); update(); })();</script>
</Base>
