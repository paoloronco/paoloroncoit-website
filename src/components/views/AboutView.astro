---
import Base from '@/layouts/Base.astro';
import CmdPath from '@/components/CmdPath.astro';
import SocialLinks from '@/components/SocialLinks.astro';
import { site, categoryColors } from '@/data/site';
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const areaKeys = ['security', 'ai', 'automation', 'cloud'] as const;
const facts = [
  { label: t('about.roleLabel'), value: site.role },
  { label: t('about.companyLabel'), value: t('about.companyValue') },
  { label: t('about.locationLabel'), value: t('about.locationValue') },
];
---
<Base title="About" description={t('about.p1')} path="/about">
  <section class="mx-auto max-w-5xl px-5 pt-16 pb-24">
    <CmdPath cmd="whoami" />
    <h1 class="anim-rise mt-3 text-4xl font-semibold tracking-tight text-text sm:text-5xl" style="animation-delay:.12s">{site.name}</h1>

    <div class="mt-10 grid grid-cols-1 gap-10 lg:grid-cols-[1fr_320px]">
      <!-- BIO -->
      <div data-reveal>
        <div class="prose">
          <p>{t('about.p1')}</p>
          <p>{t('about.p2')}</p>
          <p>{t('about.p3')}</p>
        </div>

        <div class="mt-10">
          <p class="kicker text-accent">{t('about.areasLabel')}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {areaKeys.map((k) => (
              <span
                style={`--c:${categoryColors[k]}`}
                class="inline-flex items-center gap-2 rounded-full border border-ink-600 bg-ink-800/50 px-3.5 py-1.5 text-sm text-text-dim"
              >
                <span class="h-2 w-2 rounded-full" style={`background:var(--c)`}></span>
                {t(`area.${k}.t` as any)}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- CARD DATI -->
      <aside data-reveal="right" class="lg:sticky lg:top-20 lg:self-start">
        <div class="overflow-hidden rounded-2xl border border-ink-600 bg-ink-800/40">
          <div class="flex items-center justify-center border-b border-ink-600/70 bg-ink-800/60 pt-6">
            <img src="/paolo.png" alt={site.name} width="220" height="221" loading="lazy" class="h-40 w-auto object-contain object-bottom" />
          </div>
          <div class="p-6">
            <p class="kicker text-accent">{t('about.factsTitle')}</p>
            <dl class="mt-4 space-y-3 text-sm">
              {facts.map((f) => (
                <div class="flex items-baseline justify-between gap-3 border-b border-ink-600/50 pb-3">
                  <dt class="shrink-0 font-mono text-xs uppercase tracking-wide text-muted">{f.label}</dt>
                  <dd class="text-right font-medium text-text">{f.value}</dd>
                </div>
              ))}
              <div>
                <dt class="font-mono text-xs uppercase tracking-wide text-muted">{t('about.focusLabel')}</dt>
                <dd class="mt-1.5 text-text-dim">Security · AI/LLM · Automation · Cloud</dd>
              </div>
            </dl>

            <a href={`mailto:${site.email}`} class="btn-shine mt-5 flex items-center justify-center gap-2 rounded-md bg-accent px-4 py-2.5 text-sm font-medium text-ink-900 shadow-lg shadow-accent/20 transition-all hover:-translate-y-0.5 hover:shadow-accent/40">
              {t('about.writeMe')}
            </a>
            <div class="mt-3 flex items-center justify-center gap-2">
              <SocialLinks />
              <a href={localizePath('/contact', lang)} aria-label="Contact" class="flex h-9 flex-1 items-center justify-center rounded-md border border-ink-600 font-mono text-xs text-muted transition-colors hover:border-accent hover:text-text">/contact</a>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>
</Base>
