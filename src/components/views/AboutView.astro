---
import Base from '@/layouts/Base.astro';
import CmdPath from '@/components/CmdPath.astro';
import { site, categoryColors, enterpriseSecurityArea } from '@/data/site';
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const areaKeys = ['security', 'ai', 'automation', 'cloud'] as const;
const facts: { label: string; value: string; sub?: string }[] = [
  { label: t('about.roleLabel'), value: site.role },
  { label: t('about.companyLabel'), value: 'Deloitte', sub: enterpriseSecurityArea },
  { label: t('about.locationLabel'), value: t('about.locationValue') },
];

const quickLinks = [
  { href: '/cv', label: t('nav.cv') },
  { href: '/skills', label: t('nav.skills') },
  { href: '/projects', label: t('nav.projects') },
  { href: '/writing', label: t('nav.writing') },
];
---
<Base title="About" description={t('about.p1')} path="/about">
  <section class="mx-auto max-w-5xl px-5 pt-16 pb-24">
    <CmdPath cmd="whoami" />

    <div class="mt-6 overflow-hidden border-y border-ink-600/70 py-10 sm:py-12">
      <div class="grid items-end gap-10 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="anim-rise" style="animation-delay:.12s">
          <p class="kicker text-accent">{t('about.kicker')}</p>
          <h1 class="mt-3 text-4xl font-semibold tracking-tight text-text sm:text-6xl">{site.name}</h1>

          <div class="mt-6 grid grid-cols-[1fr_8.5rem] items-end gap-4 border-y border-ink-600/70 py-4 lg:hidden">
            <dl class="divide-y divide-ink-600/70">
              {facts.map((f) => (
                <div class="py-2.5">
                  <dt class="font-mono text-[0.65rem] uppercase tracking-wide text-muted">{f.label}</dt>
                  <dd class="mt-0.5 text-sm font-medium leading-tight text-text">
                    {f.value}
                    {f.sub && <span class="mt-0.5 block text-xs font-normal text-text-dim">{f.sub}</span>}
                  </dd>
                </div>
              ))}
            </dl>
            <figure class="relative h-44 overflow-hidden">
              <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-accent/60 to-transparent"></div>
              <img
                src="/paolo.png"
                alt={site.name}
                width="549"
                height="552"
                loading="lazy"
                class="absolute bottom-0 left-1/2 w-44 max-w-none -translate-x-1/2 object-contain drop-shadow-2xl"
              />
            </figure>
          </div>

          <a href={localizePath('/contact', lang)} class="btn-shine mt-7 inline-flex items-center justify-center rounded-md bg-accent px-5 py-3 text-sm font-semibold uppercase tracking-[0.12em] text-ink-900 shadow-lg shadow-accent/20 transition-all hover:-translate-y-0.5 hover:shadow-accent/40">
            Contact
          </a>

          <div class="prose mt-7">
            <p>{t('about.p1')}</p>
            <p>{t('about.p2')}</p>
            <p>{t('about.p3')}</p>
          </div>
        </div>

        <aside data-reveal="right" class="relative hidden lg:block">
          <div class="grid gap-6 sm:grid-cols-[0.72fr_1fr] lg:grid-cols-1">
            <figure class="relative min-h-72 overflow-hidden border-b border-ink-600/80 sm:min-h-80 sm:border-b-0 sm:border-r lg:border-r-0 lg:border-b">
              <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-accent/60 to-transparent"></div>
              <img
                src="/paolo.png"
                alt={site.name}
                width="549"
                height="552"
                loading="lazy"
                class="absolute bottom-0 left-1/2 w-[18.5rem] max-w-none -translate-x-1/2 object-contain drop-shadow-2xl sm:w-[20rem] lg:w-[22rem]"
              />
            </figure>

            <div class="grid content-end">
              <p class="kicker text-accent">{t('about.factsTitle')}</p>
              <dl class="mt-4 divide-y divide-ink-600/70 border-y border-ink-600/70">
                {facts.map((f) => (
                  <div class="grid grid-cols-[7.5rem_1fr] gap-4 py-4">
                    <dt class="font-mono text-xs uppercase tracking-wide text-muted">{f.label}</dt>
                    <dd class="font-medium text-text">
                      {f.value}
                      {f.sub && <span class="mt-1 block text-sm font-normal leading-snug text-text-dim">{f.sub}</span>}
                    </dd>
                  </div>
                ))}
              </dl>
            </div>
          </div>
        </aside>
      </div>
    </div>

    <nav class="mt-8 grid gap-3 sm:grid-cols-4" aria-label={t('about.factsTitle')}>
      {quickLinks.map((link) => (
        <a
          href={localizePath(link.href, lang)}
          class="group flex items-center justify-between rounded-md border border-ink-600 bg-ink-800/30 px-4 py-3 text-sm font-medium text-text-dim transition-all hover:-translate-y-0.5 hover:border-accent hover:bg-ink-800/70 hover:text-text"
        >
          <span>{link.label}</span>
          <span class="font-mono text-muted transition-colors group-hover:text-accent">/</span>
        </a>
      ))}
    </nav>

    <div class="mt-12">
      <p class="kicker text-accent">{t('about.areasLabel')}</p>
      <div class="mt-4 flex flex-wrap gap-2">
        {areaKeys.map((k) => (
          <span
            style={`--c:${categoryColors[k]}`}
            class="inline-flex items-center gap-2 rounded-full border border-ink-600 bg-ink-800/40 px-3.5 py-1.5 text-sm text-text-dim"
          >
            <span class="h-2 w-2 rounded-full" style={`background:var(--c)`}></span>
            {t(`area.${k}.t` as any)}
          </span>
        ))}
      </div>
    </div>
  </section>
</Base>
