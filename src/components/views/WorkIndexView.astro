---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import CaseFileCard from '@/components/CaseFileCard.astro';
import { getLangFromUrl, useTranslations, localizePath, entryLang, entrySlug } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const projects = (await getCollection('work', (entry) => !entry.data.draft && entryLang(entry.id) === lang)).sort((a, b) => a.data.order - b.data.order);
const allLabel = t('work.all');
const categories = [allLabel, ...new Set(projects.map((project) => project.data.category))];
---
<Base title="Work" description={t('work.subtitle')} path="/work">
  <header class="field-section pt-14 sm:pt-20">
    <div class="field-shell grid gap-8 lg:grid-cols-[1fr_2fr]">
      <p class="field-label">01 / Case files</p>
      <div><h1 class="field-display text-[clamp(4.5rem,11vw,10rem)]">WORK<span class="text-signal">.</span></h1><p class="mt-6 max-w-xl text-lg text-muted">{t('work.subtitle')}</p></div>
    </div>
  </header>
  <section class="field-section pt-10">
    <div class="field-shell">
      {projects.length > 0 && <div class="mb-12 flex flex-wrap border-y border-ink" data-filter-bar data-all={allLabel}>{categories.map((category, index) => <button data-filter={index === 0 ? '__all__' : category} class:list={['min-h-11 border-r border-ink px-4 font-mono text-[10px] uppercase tracking-[.08em]', index === 0 ? 'bg-ink text-paper' : 'hover:bg-signal hover:text-white']}>{category}</button>)}</div>}
      {projects.length === 0 ? <div class="grid min-h-72 place-items-center border-y border-ink text-center"><div><p class="field-label">00 / Empty archive</p><p class="mt-4 max-w-md text-muted">{t('work.empty')}</p></div></div> : <div data-grid>{projects.map((project, index) => <div data-category={project.data.category} data-reveal style={`--i:${index}`}><CaseFileCard href={localizePath(`/work/${entrySlug(project.id)}`, lang)} title={project.data.title} summary={project.data.summary} category={project.data.category} stack={project.data.stack} index={index + 1} /></div>)}</div>}
    </div>
  </section>
</Base>
<script is:inline data-astro-rerun>
  (() => { const bar = document.querySelector('[data-filter-bar]'); if (!bar || bar.dataset.ready) return; bar.dataset.ready = '1'; const rows = document.querySelectorAll('[data-grid] [data-category]'); bar.addEventListener('click', (event) => { const button = event.target.closest('[data-filter]'); if (!button) return; const filter = button.dataset.filter; bar.querySelectorAll('[data-filter]').forEach((item) => item.classList.toggle('bg-ink', item === button)); rows.forEach((row) => { row.style.display = filter === '__all__' || row.dataset.category === filter ? '' : 'none'; }); }); })();
</script>
