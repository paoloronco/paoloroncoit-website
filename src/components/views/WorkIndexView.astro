---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import CaseFileCard from '@/components/CaseFileCard.astro';
import CmdPath from '@/components/CmdPath.astro';
import { getLangFromUrl, useTranslations, localizePath, entryLang, entrySlug } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = (await getCollection('work', (e) => !e.data.draft && entryLang(e.id) === lang)).sort(
  (a, b) => a.data.order - b.data.order
);
const allLabel = t('work.all');
const categories = [allLabel, ...new Set(projects.map((p) => p.data.category))];
---

<Base title="Projects" description={t('work.subtitle')} path="/projects">
  <section class="mx-auto max-w-5xl px-5 pt-16 pb-10">
    <CmdPath cmd="cd" arg="~/projects" />
    <h1 class="anim-rise mt-3 text-4xl font-semibold tracking-tight text-text" style="animation-delay:.12s">Projects</h1>
    <p class="anim-rise mt-3 max-w-2xl text-text-dim" style="animation-delay:.2s">{t('work.subtitle')}</p>

    {projects.length > 0 && (
    <div class="mt-8 flex flex-wrap gap-2" data-filter-bar data-all={allLabel}>
      {categories.map((c, i) => (
        <button
          data-filter={i === 0 ? '__all__' : c}
          class:list={[
            'rounded-full border bg-ink-900/45 px-3 py-1 font-mono text-xs backdrop-blur-sm transition-colors',
            i === 0 ? 'border-accent text-accent' : 'border-ink-600 text-muted hover:text-text',
          ]}
        >{c}</button>
      ))}
    </div>
    )}
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-16">
    {projects.length === 0 ? (
      <p class="rounded-card border border-dashed border-ink-600 p-8 text-center text-muted">{t('work.empty')}</p>
    ) : (
      <div class="grid grid-cols-1 gap-3 md:grid-cols-2" data-grid>
        {projects.map((p, i) => (
          <div data-category={p.data.category} data-reveal style={`--i:${i + 1}`}>
            <CaseFileCard href={localizePath(`/projects/${entrySlug(p.id)}`, lang)} title={p.data.title} summary={p.data.summary} category={p.data.category} stack={p.data.stack} index={i + 1} />
          </div>
        ))}
      </div>
    )}
  </section>
</Base>

<script is:inline data-astro-rerun>
  (() => {
    const bar = document.querySelector('[data-filter-bar]');
    const cards = document.querySelectorAll('[data-grid] [data-category]');
    if (!bar) return;
    bar.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-filter]');
      if (!btn) return;
      const f = btn.dataset.filter;
      bar.querySelectorAll('[data-filter]').forEach((b) => {
        const on = b === btn;
        b.classList.toggle('border-accent', on);
        b.classList.toggle('text-accent', on);
        b.classList.toggle('border-ink-600', !on);
        b.classList.toggle('text-muted', !on);
      });
      cards.forEach((c) => {
        c.style.display = f === '__all__' || c.dataset.category === f ? '' : 'none';
      });
    });
  })();
</script>
