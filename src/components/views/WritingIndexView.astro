---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import CmdPath from '@/components/CmdPath.astro';
import { getLangFromUrl, useTranslations, localizePath, entryLang, entrySlug } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const posts = (await getCollection('writing', (e) => !e.data.draft && entryLang(e.id) === lang)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const fmt = (d: Date) =>
  d.toLocaleDateString(lang === 'en' ? 'en-GB' : 'it-IT', { day: '2-digit', month: 'short', year: 'numeric' });
const readMin = (body?: string) => Math.max(1, Math.round((body?.trim().split(/\s+/).length ?? 0) / 200));
const en = lang === 'en';

// tag più frequenti (per il filtro), ordinati per frequenza
const tagCount = new Map<string, number>();
for (const p of posts) for (const tag of p.data.tags) tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
const allTags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]).map(([tag]) => tag);
---

<Base title="Writing" description={t('writing.subtitle')} path="/writing">
  <section class="lab-page-shell readable-shell mx-auto max-w-6xl px-5 pt-16 pb-8">
    <div class="lab-page-hero">
      <div>
        <CmdPath cmd="ls" arg="~/writing" note={`${posts.length}`} />
        <h1 class="anim-rise mt-4 text-5xl font-semibold leading-tight text-text sm:text-6xl" style="animation-delay:.12s">Writing</h1>
        <p class="anim-rise mt-4 max-w-2xl text-base leading-relaxed text-text-dim" style="animation-delay:.2s">{t('writing.subtitle')}</p>
      </div>
      <div class="lab-page-stat" aria-label={en ? 'Published articles' : 'Articoli pubblicati'}>
        <span>{String(posts.length).padStart(2, '0')}</span>
        <strong>{t('writing.count')}</strong>
      </div>
    </div>

    <!-- Ricerca -->
    <div class="lab-search-panel anim-rise mt-8" style="animation-delay:.26s">
      <div class="relative">
        <svg class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4.3-4.3"></path>
        </svg>
        <input
          type="search"
          data-search-input
          placeholder={t('writing.search')}
          autocomplete="off"
          class="readable-input w-full rounded-lg border border-ink-600 bg-ink-800/75 py-2.5 pl-10 pr-4 text-sm text-text backdrop-blur-md placeholder:text-muted transition-colors focus:border-accent focus:outline-none"
        />
      </div>

      <!-- Filtro tag -->
      <div class="lab-filterbar readable-filters mt-4 flex flex-wrap gap-2" data-tag-bar>
        <button data-tag="__all__" class="readable-chip rounded-full border border-accent bg-ink-900/45 px-3 py-1 font-mono text-xs text-accent backdrop-blur-sm transition-colors">{t('writing.allTags')}</button>
        {allTags.map((tag) => (
          <button data-tag={tag} class="readable-chip rounded-full border border-ink-600 bg-ink-900/45 px-3 py-1 font-mono text-xs text-muted backdrop-blur-sm transition-colors hover:text-text">#{tag}</button>
        ))}
      </div>
    </div>
  </section>

  <section class="lab-page-shell readable-shell mx-auto max-w-6xl px-5 pb-20">
    {posts.length === 0 && (
      <p class="rounded-card border border-dashed border-ink-600 p-8 text-center text-muted">{t('writing.empty')}</p>
    )}

    <ul data-post-list class="writing-grid readable-panel grid gap-4">
      {posts.map((p, i) => {
        const tags = p.data.tags ?? [];
        const hay = `${p.data.title} ${p.data.description} ${tags.join(' ')}`.toLowerCase();
        return (
        <li data-post data-search={hay} data-tags={tags.join(' ')} data-reveal style={`--i:${Math.min(i, 8)}`} class="article-row">
            <a href={localizePath(`/writing/${entrySlug(p.id)}`, lang)} class="article-card readable-card group block px-4 py-5 transition-colors hover:bg-ink-800/45 sm:px-5">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <time class="readable-meta font-mono text-xs text-muted">{fmt(p.data.pubDate)}</time>
                <span class="text-ink-500">·</span>
                <span class="readable-meta font-mono text-xs text-muted">{readMin(p.body)} {t('writing.min')}</span>
                <div class="flex flex-wrap gap-1.5">
                  {tags.slice(0, 3).map((tag) => <span class="font-mono text-[11px] text-accent/80">#{tag}</span>)}
                </div>
              </div>
              <h2 class="readable-title mt-1.5 text-lg font-medium leading-snug text-text-dim transition-colors group-hover:text-accent">{p.data.title}</h2>
              <p class="readable-summary mt-1 text-sm text-muted">{p.data.description}</p>
            </a>
          </li>
        );
      })}
    </ul>

    <p data-no-results hidden class="py-12 text-center text-muted">{t('writing.noResults')}</p>
  </section>
</Base>

<style>
  .writing-grid {
    grid-template-columns: 1fr;
  }

  @media (min-width: 900px) {
    .writing-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: stretch;
    }

    .article-row,
    .article-card {
      height: 100%;
    }
  }

  .article-card {
    background: color-mix(in oklab, var(--color-ink-800) 80%, transparent);
    border: 1px solid color-mix(in oklab, var(--color-ink-600) 80%, transparent);
    border-radius: 8px;
    padding: 1.15rem 1.3rem;
  }

  .article-card:hover {
    background: color-mix(in oklab, var(--color-ink-800) 92%, transparent);
  }

  .article-row {
    min-width: 0;
  }

  .article-card .readable-title {
    margin-top: 0.85rem;
    font-size: 1.16rem;
    line-height: 1.35;
  }

  .article-card .readable-summary {
    margin-top: 0.55rem;
    font-size: 0.94rem;
    line-height: 1.68;
  }

  .article-card .readable-meta {
    font-size: 0.72rem;
    letter-spacing: 0.015em;
  }
</style>

<script is:inline data-astro-rerun>
  (() => {
    const input = document.querySelector('[data-search-input]');
    const bar = document.querySelector('[data-tag-bar]');
    const items = Array.from(document.querySelectorAll('[data-post]'));
    const empty = document.querySelector('[data-no-results]');
    if (!input || !bar) return;

    let q = '';
    let tag = '__all__';

    const apply = () => {
      let shown = 0;
      items.forEach((li) => {
        const okQ = !q || (li.dataset.search || '').includes(q);
        const okTag = tag === '__all__' || (' ' + (li.dataset.tags || '') + ' ').includes(' ' + tag + ' ');
        const show = okQ && okTag;
        li.style.display = show ? '' : 'none';
        if (show) shown++;
      });
      if (empty) empty.hidden = shown !== 0;
    };

    input.addEventListener('input', (e) => { q = e.target.value.trim().toLowerCase(); apply(); });
    bar.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-tag]');
      if (!btn) return;
      tag = btn.dataset.tag;
      bar.querySelectorAll('[data-tag]').forEach((b) => {
        const on = b === btn;
        b.classList.toggle('border-accent', on);
        b.classList.toggle('text-accent', on);
        b.classList.toggle('border-ink-600', !on);
        b.classList.toggle('text-muted', !on);
      });
      apply();
    });
  })();
</script>
