---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import { getLangFromUrl, useTranslations, localizePath, entryLang, entrySlug } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const posts = (await getCollection('writing', (entry) => !entry.data.draft && entryLang(entry.id) === lang)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const fmt = (date: Date) => date.toLocaleDateString(lang === 'en' ? 'en-GB' : 'it-IT', { day: '2-digit', month: 'short', year: 'numeric' });
const readMin = (body?: string) => Math.max(1, Math.round((body?.trim().split(/\s+/).length ?? 0) / 200));
const tagCount = new Map<string, number>(); for (const post of posts) for (const tag of post.data.tags) tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
const allTags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]).slice(0, 12).map(([tag]) => tag);
---
<Base title="Writing" description={t('writing.subtitle')} path="/writing">
  <header class="field-section pt-14 sm:pt-20"><div class="field-shell grid gap-8 lg:grid-cols-[1fr_2fr]"><p class="field-label">02 / Field notes · {posts.length}</p><div><h1 class="field-display text-[clamp(4.3rem,11vw,10rem)]">WRITING<span class="text-signal">.</span></h1><p class="mt-6 max-w-xl text-lg text-muted">{t('writing.subtitle')}</p></div></div></header>
  <section class="field-section pt-10"><div class="field-shell">
    <div class="grid gap-3 border-y border-ink py-3 lg:grid-cols-[1fr_2fr]">
      <input type="search" data-search-input placeholder={t('writing.search')} autocomplete="off" class="min-h-12 border border-ink bg-transparent px-4 font-mono text-xs placeholder:text-muted focus:outline-none" />
      <div class="flex flex-wrap" data-tag-bar><button data-tag="__all__" class="min-h-11 border border-ink bg-ink px-3 font-mono text-[10px] uppercase text-paper">{t('writing.allTags')}</button>{allTags.map((tag) => <button data-tag={tag} class="min-h-11 border-y border-r border-ink px-3 font-mono text-[10px] hover:bg-signal hover:text-white">#{tag}</button>)}</div>
    </div>
    <ul data-post-list class="mt-12">
      {posts.map((post, index) => { const tags = post.data.tags ?? []; const hay = `${post.data.title} ${post.data.description} ${tags.join(' ')}`.toLowerCase(); return <li data-post data-search={hay} data-tags={tags.join(' ')} data-reveal style={`--i:${Math.min(index, 8)}`}><a href={localizePath(`/writing/${entrySlug(post.id)}`, lang)} class="group grid gap-3 border-b border-ink py-5 transition-all hover:bg-signal hover:px-4 hover:text-white sm:grid-cols-[7rem_1fr_auto]"><div class="font-mono text-[10px] uppercase"><time>{fmt(post.data.pubDate)}</time><span class="mt-2 block">{readMin(post.body)} {t('writing.min')}</span></div><div><h2 class="text-xl font-semibold leading-tight">{post.data.title}</h2><p class="mt-1 max-w-2xl text-sm opacity-70">{post.data.description}</p></div><span class="font-mono text-xs">↗</span></a></li>; })}
    </ul><p data-no-results hidden class="border-y border-ink py-16 text-center text-muted">{t('writing.noResults')}</p>
  </div></section>
</Base>
<script is:inline data-astro-rerun>
  (() => { const input = document.querySelector('[data-search-input]'); const bar = document.querySelector('[data-tag-bar]'); if (!input || !bar || input.dataset.ready) return; input.dataset.ready = '1'; const items = [...document.querySelectorAll('[data-post]')]; const empty = document.querySelector('[data-no-results]'); let query = ''; let tag = '__all__'; const apply = () => { let shown = 0; items.forEach((item) => { const show = (!query || (item.dataset.search || '').includes(query)) && (tag === '__all__' || (` ${item.dataset.tags || ''} `).includes(` ${tag} `)); item.style.display = show ? '' : 'none'; if (show) shown++; }); if (empty) empty.hidden = shown !== 0; }; input.addEventListener('input', (event) => { query = event.target.value.trim().toLowerCase(); apply(); }); bar.addEventListener('click', (event) => { const button = event.target.closest('[data-tag]'); if (!button) return; tag = button.dataset.tag; bar.querySelectorAll('[data-tag]').forEach((item) => { item.classList.toggle('bg-ink', item === button); item.classList.toggle('text-paper', item === button); }); apply(); }); })();
</script>
