---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import { getLangFromUrl, useTranslations, localizePath, entryLang, entrySlug } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const posts = (await getCollection('writing', (e) => !e.data.draft && entryLang(e.id) === lang)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const fmt = (d: Date) =>
  d.toLocaleDateString(lang === 'en' ? 'en-GB' : 'it-IT', { day: '2-digit', month: 'short', year: 'numeric' });
---

<Base title="Writing" description={t('writing.subtitle')} path="/writing">
  <section class="mx-auto max-w-3xl px-5 pt-16 pb-10">
    <p class="kicker anim-rise" style="animation-delay:.05s">{t('writing.kicker')}</p>
    <h1 class="anim-rise mt-3 text-4xl font-semibold tracking-tight text-text" style="animation-delay:.12s">Writing</h1>
    <p class="anim-rise mt-3 text-text-dim" style="animation-delay:.2s">{t('writing.subtitle')}</p>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-16">
    {posts.length === 0 && (
      <p class="rounded-card border border-dashed border-ink-600 p-8 text-center text-muted">{t('writing.empty')}</p>
    )}
    <ul class="divide-y divide-ink-600/70 border-y border-ink-600/70">
      {posts.map((p, i) => (
        <li data-reveal style={`--i:${Math.min(i, 8)}`}>
          <a href={localizePath(`/writing/${entrySlug(p.id)}`, lang)} class="group block py-5">
            <div class="flex flex-wrap items-baseline gap-3">
              <time class="font-mono text-xs text-muted">{fmt(p.data.pubDate)}</time>
              <div class="flex gap-1.5">
                {p.data.tags.slice(0, 3).map((tag) => <span class="font-mono text-[11px] text-accent/80">#{tag}</span>)}
              </div>
            </div>
            <h2 class="mt-1.5 text-lg font-medium text-text-dim group-hover:text-accent">{p.data.title}</h2>
            <p class="mt-1 text-sm text-muted">{p.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
