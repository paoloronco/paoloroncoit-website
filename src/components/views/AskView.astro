---
import Base from '@/layouts/Base.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const fallback = t('ask.fallback');
---
<Base title={t('ask.title')} description={t('ask.subtitle')} path="/ask">
  <section class="mx-auto max-w-2xl px-5 pt-16 pb-16">
    <p class="kicker">{t('ask.kicker')}</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-text">{t('ask.title')}</h1>
    <p class="mt-3 text-text-dim">{t('ask.subtitle')}</p>

    <div class="mt-8 rounded-card border border-ink-600 bg-ink-800/50">
      <div data-chat-log class="min-h-[180px] space-y-3 p-4 text-sm"></div>
      <form data-chat-form class="flex items-center gap-2 border-t border-ink-600 p-3">
        <input data-chat-input type="text" placeholder={t('ask.placeholder')} class="w-full bg-transparent px-2 py-2 text-sm text-text placeholder:text-muted focus:outline-none" autocomplete="off" />
        <button class="rounded-md bg-accent px-3 py-2 text-sm font-medium text-ink-900 hover:opacity-90">{t('ask.send')}</button>
      </form>
    </div>

    <p class="mt-4 font-mono text-xs text-muted">{t('ask.note')}</p>
  </section>

  <script is:inline data-astro-rerun define:vars={{ fallback }}>
    (() => {
      const log = document.querySelector('[data-chat-log]');
      const form = document.querySelector('[data-chat-form]');
      const input = document.querySelector('[data-chat-input]');
      if (!form) return;
      const bubble = (who, text) => {
        const wrap = document.createElement('div');
        wrap.className = who === 'me' ? 'text-right' : '';
        wrap.innerHTML = '<span class="inline-block max-w-[85%] rounded-lg px-3 py-2 ' + (who === 'me' ? 'bg-accent text-ink-900' : 'bg-ink-700 text-text-dim') + '"></span>';
        wrap.querySelector('span').textContent = text;
        log.appendChild(wrap);
        log.scrollTop = log.scrollHeight;
      };
      const send = (q) => {
        if (!q) return;
        bubble('me', q);
        setTimeout(() => bubble('ai', fallback), 250);
      };
      form.addEventListener('submit', (e) => { e.preventDefault(); const q = input.value.trim(); input.value = ''; send(q); });
      const q = new URLSearchParams(location.search).get('q');
      if (q) { send(q); }
    })();
  </script>
</Base>
