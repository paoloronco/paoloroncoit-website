---
import Base from '@/layouts/Base.astro';
import CmdPath from '@/components/CmdPath.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const i18n = {
  searching: t('chat.searching'),
  found: t('chat.found'),
  empty: t('chat.empty'),
  error: t('chat.error'),
  greeting: t('chat.greeting'),
};
---
<Base title={t('ask.title')} description={t('ask.subtitle')} path="/ask">
  <section class="mx-auto max-w-2xl px-5 pt-16 pb-24">
    <CmdPath cmd="./ask.sh" />
    <h1 class="anim-rise mt-3 text-4xl font-semibold tracking-tight text-text sm:text-5xl" style="animation-delay:.12s">{t('ask.title')}</h1>
    <p class="anim-rise mt-3 text-text-dim" style="animation-delay:.2s">{t('ask.subtitle')}</p>

    <div class="anim-rise mt-8 overflow-hidden rounded-2xl border border-ink-600 bg-ink-800/40" style="animation-delay:.28s">
      <div data-ask-log class="min-h-[220px] max-h-[50vh] space-y-3 overflow-y-auto p-4 text-sm">
        <div><span class="inline-block max-w-[85%] rounded-2xl rounded-bl-sm bg-ink-700 px-3 py-2 text-text-dim">{i18n.greeting}</span></div>
      </div>
      <form data-ask-form class="flex items-center gap-2 border-t border-ink-600 p-3">
        <input data-ask-input type="text" placeholder={t('ask.placeholder')} class="w-full rounded-lg bg-ink-900/60 px-3 py-2.5 text-sm text-text placeholder:text-muted focus:outline-none focus:ring-1 focus:ring-accent" autocomplete="off" />
        <button type="submit" aria-label={t('ask.send')} class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-accent text-ink-900 transition-opacity hover:opacity-90">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
        </button>
      </form>
    </div>

    <p class="mt-4 font-mono text-xs leading-relaxed text-muted">{t('ask.note')}</p>
  </section>

  <script is:inline data-astro-rerun define:vars={{ i18n }}>
    (() => {
      const log = document.querySelector('[data-ask-log]');
      const form = document.querySelector('[data-ask-form]');
      const input = document.querySelector('[data-ask-input]');
      const submitBtn = form && form.querySelector('button[type="submit"]');
      if (!form || !log || !input) return;
      if (window.__askViewCleanup) window.__askViewCleanup();
      const lifecycle = new AbortController();
      let activeRequest = null;
      let activeRequestTimer = null;
      let busy = false;
      const requestTimeoutMs = 65000;

      const setBusy = (v) => {
        busy = v;
        if (input) {
          input.disabled = v;
          input.setAttribute('aria-busy', v ? 'true' : 'false');
        }
        if (submitBtn) submitBtn.disabled = v;
        form.toggleAttribute('data-busy', v);
      };

      window.__askViewCleanup = () => {
        lifecycle.abort();
        if (activeRequest) {
          try { activeRequest.abort(); } catch (_) {}
        }
        if (activeRequestTimer) clearTimeout(activeRequestTimer);
      };

      let sid;
      try {
        sid = sessionStorage.getItem('chatSid');
        if (!sid) { sid = 'web-' + Date.now().toString(36) + Math.random().toString(36).slice(2, 8); sessionStorage.setItem('chatSid', sid); }
      } catch (e) { sid = 'web-' + Date.now(); }

      const scroll = () => { log.scrollTop = log.scrollHeight; };
      const escHtml = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
      const fmt = (s) => escHtml(s).replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>');

      const bubble = (who, text) => {
        const wrap = document.createElement('div');
        wrap.className = who === 'me' ? 'text-right' : '';
        const span = document.createElement('span');
        span.className = 'inline-block max-w-[85%] rounded-2xl px-3 py-2 ' + (who === 'me' ? 'rounded-br-sm bg-accent text-ink-900' : 'rounded-bl-sm bg-ink-700 text-text-dim');
        span.textContent = text;
        wrap.appendChild(span);
        log.appendChild(wrap);
        scroll();
      };

      const typing = () => {
        const wrap = document.createElement('div');
        const span = document.createElement('span');
        span.className = 'inline-block rounded-2xl rounded-bl-sm bg-ink-700 px-3 py-2.5';
        span.innerHTML = '<span class="typing-dots"><span></span><span></span><span></span></span>';
        wrap.appendChild(span);
        log.appendChild(wrap);
        scroll();
        return wrap;
      };

      const renderResults = (data) => {
        const wrap = document.createElement('div');
        wrap.className = 'space-y-2';
        const intro = document.createElement('p');
        intro.className = 'text-xs text-muted';
        intro.textContent = i18n.found;
        wrap.appendChild(intro);
        (data.results || []).forEach((r) => {
          const hasUrl = r && r.url && r.url !== '#';
          const el = document.createElement(hasUrl ? 'a' : 'div');
          el.className = 'chat-card';
          if (hasUrl) { el.href = r.url; el.target = '_blank'; el.rel = 'noopener'; }
          el.innerHTML = '<span class="chat-card__title"></span><span class="chat-card__body"></span>';
          el.querySelector('.chat-card__title').textContent = (r && r.title) || '';
          el.querySelector('.chat-card__body').innerHTML = fmt(r && r.summary);
          wrap.appendChild(el);
        });
        log.appendChild(wrap);
        scroll();
      };

      const render = (data) => {
        if (data && data.type === 'search_results') {
          if (!data.results || !data.results.length) return bubble('ai', i18n.empty);
          return renderResults(data);
        }
        const text = data && (data.reply || data.output || data.message || data.answer || data.text);
        bubble('ai', text || i18n.empty);
      };

      const send = async (q) => {
        if (!q || busy) return;
        setBusy(true);
        bubble('me', q);
        const tnode = typing();
        const request = new AbortController();
        activeRequest = request;
        activeRequestTimer = setTimeout(() => request.abort(), requestTimeoutMs);
        try {
          const r = await fetch('/api/ask', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: q, sessionId: sid }),
            signal: request.signal,
          });
          const data = await r.json().catch(() => null);
          if (tnode && tnode.isConnected) tnode.remove();
          if (!r.ok || !data) bubble('ai', i18n.error);
          else render(data);
        } catch (e) {
          if (tnode && tnode.isConnected) tnode.remove();
          if (!lifecycle.signal.aborted) bubble('ai', i18n.error);
        } finally {
          if (activeRequest === request) activeRequest = null;
          if (activeRequestTimer) {
            clearTimeout(activeRequestTimer);
            activeRequestTimer = null;
          }
          setBusy(false);
          scroll();
          try { input && input.focus({ preventScroll: true }); } catch (_) {}
        }
      };

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (busy) return;
        const q = input.value.trim();
        if (!q) return;
        input.value = '';
        send(q);
      }, { signal: lifecycle.signal });
      const q = new URLSearchParams(location.search).get('q');
      if (q) { input.value = ''; send(q); }
    })();
  </script>
</Base>
