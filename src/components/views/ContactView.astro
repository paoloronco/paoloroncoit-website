---
import Base from '@/layouts/Base.astro';
import { site } from '@/data/site';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<Base title={t('contact.title')} description={t('contact.subtitle')} path="/contact">
  <section class="mx-auto max-w-2xl px-5 pt-16 pb-16">
    <p class="kicker">{t('contact.kicker')}</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-text">{t('contact.title')}</h1>
    <p class="mt-3 text-text-dim">{t('contact.subtitle')}</p>

    <div class="mt-8 space-y-3">
      <a href={`mailto:${site.email}`} class="flex items-center justify-between rounded-card border border-ink-600 p-4 hover:border-accent">
        <span class="text-text-dim">{t('contact.email')}</span>
        <span class="font-mono text-sm text-text">{site.email}</span>
      </a>
      <a href={site.socials.linkedin} class="flex items-center justify-between rounded-card border border-ink-600 p-4 hover:border-accent">
        <span class="text-text-dim">LinkedIn</span><span class="font-mono text-sm text-accent">→</span>
      </a>
      <a href={site.socials.github} class="flex items-center justify-between rounded-card border border-ink-600 p-4 hover:border-accent">
        <span class="text-text-dim">GitHub</span><span class="font-mono text-sm text-accent">→</span>
      </a>
    </div>

    <div class="mt-8 rounded-card border border-ink-600 bg-ink-800/50 p-4">
      <p class="kicker">PGP</p>
      <p class="mt-2 text-sm text-text-dim">{t('contact.pgpText')} <code class="font-mono text-text">XXXX XXXX XXXX XXXX</code></p>
    </div>
  </section>
</Base>
