---
import Base from '@/layouts/Base.astro';
import CmdPath from '@/components/CmdPath.astro';
import { site } from '@/data/site';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const profiles = [
  {
    label: 'GitHub',
    handle: '@paoloronco',
    note: t('contact.githubNote'),
    href: site.socials.github,
    logo: '/logos/social/github-mark.png',
    logoWrapClass: 'contact-profile__logo-wrap--mark',
    logoClass: 'contact-profile__logo--mark',
    accent: '#f3f6fc',
  },
  {
    label: 'LinkedIn',
    handle: 'paolo-ronco',
    note: t('contact.linkedinNote'),
    href: site.socials.linkedin,
    logo: '/logos/social/linkedin.png',
    logoClass: 'contact-profile__logo--wordmark',
    accent: '#0a66c2',
  },
  {
    label: 'Hugging Face',
    handle: '@paoloronco',
    note: t('contact.hfNote'),
    href: site.socials.huggingface,
    logo: '/logos/social/huggingface.png',
    logoClass: 'contact-profile__logo--wordmark contact-profile__logo--hf',
    accent: '#ffd21e',
  },
];
---
<Base title={t('contact.title')} description={t('contact.subtitle')} path="/contact">
  <section class="mx-auto max-w-4xl px-5 pt-16 pb-24">
    <CmdPath cmd="cat" arg="contact.md" />

    <div class="mt-6 grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
      <div class="anim-rise" style="animation-delay:.12s">
        <p class="kicker text-accent">{t('contact.kicker')}</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-text sm:text-6xl">{t('contact.title')}</h1>
        <p class="mt-4 max-w-xl text-lg leading-relaxed text-text-dim">{t('contact.subtitle')}</p>
      </div>

      <a
        href={`mailto:${site.email}`}
        data-reveal="right"
        class="contact-email group"
      >
        <span class="contact-email__meta">{t('contact.email')}</span>
        <span class="contact-email__value">{site.email}</span>
        {t('contact.emailNote') && <span class="contact-email__note">{t('contact.emailNote')}</span>}
        <span class="contact-email__arrow" aria-hidden="true">-&gt;</span>
      </a>
    </div>

    <div class="mt-14 border-t border-ink-600/70 pt-8">
      <p class="kicker text-accent">{t('contact.socialTitle')}</p>
      <div class="mt-5 grid gap-3 sm:grid-cols-3">
        {profiles.map((profile, i) => (
          <a
            href={profile.href}
            target="_blank"
            rel="noopener"
            aria-label={`${profile.label}: ${profile.handle}`}
            data-reveal
            style={`--i:${i}; --profile-accent:${profile.accent}`}
            class="contact-profile group"
          >
            <span class="contact-profile__brand" aria-hidden="true">
              <span class={`contact-profile__logo-wrap ${profile.logoWrapClass ?? ''}`}>
                <img
                  src={profile.logo}
                  alt=""
                  width="180"
                  height="54"
                  loading="lazy"
                  class={profile.logoClass}
                />
              </span>
            </span>
            <span class="contact-profile__handle">{profile.handle}</span>
            <span class="contact-profile__note">{profile.note}</span>
            <span class="contact-profile__action">
              {t('contact.openProfile')}
              <span aria-hidden="true">-&gt;</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-email {
    position: relative;
    display: grid;
    gap: 0.55rem;
    min-height: 12rem;
    align-content: end;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--color-accent) 42%, var(--color-ink-600));
    border-radius: var(--radius-card);
    background:
      radial-gradient(90% 120% at 100% 0%, color-mix(in oklab, var(--color-accent) 18%, transparent), transparent 58%),
      linear-gradient(135deg, color-mix(in oklab, var(--color-ink-800) 78%, var(--color-accent)), var(--color-ink-800));
    padding: 1.25rem;
    color: var(--color-text);
    text-decoration: none;
    transition:
      border-color 0.28s var(--ease-out-quart),
      box-shadow 0.28s var(--ease-out-quart),
      transform 0.3s var(--ease-out-expo);
  }

  .contact-email:hover {
    border-color: var(--color-accent);
    box-shadow: 0 24px 52px -34px color-mix(in oklab, var(--color-accent) 70%, transparent);
    transform: translateY(-3px);
  }

  .contact-email__meta,
  .contact-profile__action {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 650;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .contact-email__meta {
    color: var(--color-accent);
  }

  .contact-email__value {
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 4vw, 2.35rem);
    font-weight: 680;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .contact-email__note {
    max-width: 28rem;
    color: var(--color-text-dim);
  }

  .contact-email__arrow {
    position: absolute;
    top: 1.15rem;
    right: 1.25rem;
    color: var(--color-accent);
    font-family: var(--font-mono);
    transition: transform 0.28s var(--ease-out-expo);
  }

  .contact-email:hover .contact-email__arrow,
  .contact-profile:hover .contact-profile__action span {
    transform: translateX(0.18rem);
  }

  .contact-profile {
    display: flex;
    min-height: 15rem;
    flex-direction: column;
    gap: 0.8rem;
    border: 1px solid var(--color-ink-600);
    border-radius: var(--radius-card);
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--profile-accent) 8%, transparent), transparent 38%),
      color-mix(in oklab, var(--color-ink-800) 72%, transparent);
    padding: 1rem;
    color: var(--color-text);
    text-decoration: none;
    transition:
      border-color 0.28s var(--ease-out-quart),
      background-color 0.28s var(--ease-out-quart),
      transform 0.3s var(--ease-out-expo);
  }

  .contact-profile:hover {
    border-color: color-mix(in oklab, var(--profile-accent) 72%, var(--color-ink-600));
    background-color: var(--color-ink-800);
    transform: translateY(-3px);
  }

  .contact-profile__brand {
    display: flex;
    align-items: center;
    min-height: 4.15rem;
    border-bottom: 1px solid color-mix(in oklab, var(--profile-accent) 30%, var(--color-ink-600));
    padding-bottom: 0.9rem;
  }

  .contact-profile__logo-wrap {
    display: flex;
    min-height: 3.25rem;
    width: 100%;
    align-items: center;
    justify-content: flex-start;
    border: 1px solid color-mix(in oklab, var(--profile-accent) 60%, var(--color-ink-600));
    border-radius: 0.58rem;
    background: color-mix(in oklab, var(--profile-accent) 14%, transparent);
    padding: 0.65rem 0.75rem;
  }

  .contact-profile__logo-wrap--mark {
    justify-content: center;
  }

  .contact-profile__logo-wrap img {
    display: block;
    width: auto;
    height: auto;
    max-height: 2.15rem;
    max-width: 10.5rem;
    object-fit: contain;
    object-position: left center;
  }

  .contact-profile__logo-wrap .contact-profile__logo--mark {
    max-height: 2.85rem;
    max-width: 2.85rem;
    filter: invert(1) brightness(0.94);
    opacity: 0.92;
  }

  .contact-profile__logo-wrap .contact-profile__logo--hf {
    max-height: 2.45rem;
    max-width: 11.25rem;
  }

  .contact-profile__handle {
    color: var(--profile-accent);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    overflow-wrap: anywhere;
  }

  .contact-profile__note {
    color: var(--color-text-dim);
    line-height: 1.55;
  }

  .contact-profile__action {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: auto;
    color: var(--color-muted);
    transition: color 0.22s var(--ease-out-quart);
  }

  .contact-profile__action span {
    display: inline-block;
    color: var(--profile-accent);
    transition: transform 0.28s var(--ease-out-expo);
  }

  .contact-profile:hover .contact-profile__action {
    color: var(--color-text);
  }
</style>
