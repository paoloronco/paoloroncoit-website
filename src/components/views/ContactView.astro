---
import Base from '@/layouts/Base.astro';
import CmdPath from '@/components/CmdPath.astro';
import { site } from '@/data/site';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const channels = [
  { label: t('contact.email'), value: site.email, href: `mailto:${site.email}`, mono: true },
  { label: 'LinkedIn', value: 'paolo-ronco', href: site.socials.linkedin },
  { label: 'GitHub', value: 'paoloronco', href: site.socials.github },
  { label: 'Hugging Face', value: 'paoloronco', href: site.socials.huggingface },
];
---
<Base title={t('contact.title')} description={t('contact.subtitle')} path="/contact">
  <section class="field-shell max-w-5xl pt-14 pb-24 sm:pt-20">
    <CmdPath cmd="cat" arg="contact.md" />
    <h1 class="field-display anim-rise mt-6 text-[clamp(4rem,10vw,8rem)]" style="animation-delay:.12s">{t('contact.title')}<span class="text-signal">.</span></h1>
    <p class="anim-rise mt-3 text-text-dim" style="animation-delay:.2s">{t('contact.subtitle')}</p>

    <div class="mt-10 space-y-3">
      {channels.map((c, i) => (
        <a
          href={c.href}
          target={c.href.startsWith('mailto:') ? undefined : '_blank'}
          rel={c.href.startsWith('mailto:') ? undefined : 'noopener'}
          data-reveal
          style={`--i:${i}`}
          class="group flex min-h-20 items-center justify-between gap-4 border-b border-ink p-4 transition-all first:border-t hover:bg-signal hover:px-6 hover:text-white"
        >
          <span class="text-text-dim transition-colors group-hover:text-text">{c.label}</span>
          <span class={`text-sm ${c.mono ? 'font-mono text-text' : 'font-mono text-muted group-hover:text-accent'}`}>
            {c.value} <span class="text-accent">→</span>
          </span>
        </a>
      ))}
    </div>

    <div class="mt-8 border border-ink p-5" data-reveal>
      <p class="kicker text-accent">PGP</p>
      <p class="mt-2 text-sm leading-relaxed text-muted">{t('contact.pgpText')}</p>
    </div>
  </section>
</Base>
