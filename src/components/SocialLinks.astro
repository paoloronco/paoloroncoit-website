---

{links.map((link) => (
  <a
    href={link.href}
    target="_blank"
    rel="noopener"
    aria-label={link.label}
    title={link.label}
    class={`social-link ${link.className}`}
  >
    <span class="social-link__mark" set:html={link.icon} />
    <span class="social-link__label" aria-hidden="true">{link.label}</span>
  </a>
))}

<style>
  .social-link {
    --brand: var(--color-accent);
    --brand-soft: color-mix(in oklab, var(--brand) 18%, transparent);

    display: inline-flex;
    width: 2.25rem;
    height: 2.25rem;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    overflow: hidden;
    border: 1px solid var(--color-ink-600);
    border-radius: 0.45rem;
    background: color-mix(in oklab, var(--color-ink-800) 28%, transparent);
    color: var(--color-muted);
    text-decoration: none;
    white-space: nowrap;
    transition:
      width 0.36s var(--ease-out-expo),
      transform 0.36s var(--ease-out-expo),
      border-color 0.25s var(--ease-out-quart),
      background 0.25s var(--ease-out-quart),
      color 0.25s var(--ease-out-quart),
      box-shadow 0.36s var(--ease-out-expo);
  }

  .social-link--github { --brand: #f3f6fc; }
  .social-link--linkedin { --brand: #0a66c2; }
  .social-link--hf { --brand: #ffd21e; }
  .social-link--n8n {
    --brand: #ea4b71;
    width: 3.6rem;
    color: var(--color-text);
  }

  .social-link__mark {
    display: inline-flex;
    min-width: 1.2rem;
    align-items: center;
    justify-content: center;
    transition:
      transform 0.36s var(--ease-out-expo),
      color 0.25s var(--ease-out-quart);
  }

  :global(.social-link__svg) {
    width: 1.125rem;
    height: 1.125rem;
  }

  :global(.social-link__svg--sm) {
    width: 1.0625rem;
    height: 1.0625rem;
  }

  :global(.social-link__hf) {
    color: #ffd21e;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0;
  }

  :global(.social-link__n8n) {
    width: 2.55rem;
    height: auto;
    color: var(--color-text);
    transition: width 0.36s var(--ease-out-expo), color 0.25s var(--ease-out-quart);
  }

  .social-link__label {
    max-width: 0;
    opacity: 0;
    transform: translateX(-0.2rem);
    color: var(--brand);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0;
    transition:
      max-width 0.36s var(--ease-out-expo),
      opacity 0.22s var(--ease-out-quart),
      transform 0.36s var(--ease-out-expo);
  }

  .social-link--n8n .social-link__label {
    display: none;
  }

  .social-link:hover,
  .social-link:focus-visible {
    border-color: color-mix(in oklab, var(--brand) 72%, var(--color-ink-600));
    background: var(--brand-soft);
    color: var(--brand);
    transform: translateY(-2px);
    box-shadow: 0 18px 40px -24px color-mix(in oklab, var(--brand) 70%, transparent);
  }

  .social-link:hover .social-link__mark,
  .social-link:focus-visible .social-link__mark {
    transform: scale(1.12);
  }

  .social-link:hover .social-link__label,
  .social-link:focus-visible .social-link__label {
    max-width: 7.5rem;
    opacity: 1;
    transform: none;
  }

  .social-link--n8n:hover,
  .social-link--n8n:focus-visible {
    width: 5.9rem;
  }

  .social-link--n8n:hover :global(.social-link__n8n),
  .social-link--n8n:focus-visible :global(.social-link__n8n) {
    width: 4.85rem;
  }

  @media (min-width: 768px) {
    .social-link:hover,
    .social-link:focus-visible {
      width: 7.5rem;
    }

    .social-link--linkedin:hover,
    .social-link--linkedin:focus-visible {
      width: 7.2rem;
    }

    .social-link--hf:hover,
    .social-link--hf:focus-visible {
      width: 8.35rem;
    }

    .social-link--n8n:hover,
    .social-link--n8n:focus-visible {
      width: 6.5rem;
    }
  }

  @media (max-width: 767px) {
    .social-link__label {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .social-link,
    .social-link__mark,
    .social-link__label,
    :global(.social-link__n8n) {
      transition-duration: 0.01ms;
    }
  }
</style>
