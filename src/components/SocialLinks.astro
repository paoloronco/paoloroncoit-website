---
// Icone social — path ufficiali (Simple Icons). Un solo punto di verità,
// usato sia nell'hero della home sia nella card About.
import { site } from '@/data/site';
const cls =
  'flex h-9 w-9 items-center justify-center rounded-md border border-ink-600 text-muted transition-colors hover:border-accent hover:text-text';
---
<a href={site.socials.github} target="_blank" rel="noopener" aria-label="GitHub" class={cls}>
  <svg viewBox="0 0 24 24" fill="currentColor" class="h-[18px] w-[18px]" aria-hidden="true">
    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z"/>
  </svg>
</a>
<a href={site.socials.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" class={cls}>
  <svg viewBox="0 0 24 24" fill="currentColor" class="h-[17px] w-[17px]" aria-hidden="true">
    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
  </svg>
</a>
<a href={site.socials.huggingface} target="_blank" rel="noopener" aria-label="Hugging Face" class={cls}>
  <span class="font-mono text-[11px] font-bold">HF</span>
</a>
<a href={site.socials.n8n} target="_blank" rel="noopener" aria-label="n8n Creator" title="n8n Creator" class={cls}>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="h-[20px] w-[20px]" aria-hidden="true">
    <circle cx="5" cy="12" r="2.2" />
    <circle cx="12" cy="7" r="2.2" />
    <circle cx="12" cy="17" r="2.2" />
    <circle cx="19" cy="12" r="2.2" />
    <path d="M7 11l3.1-2.2" />
    <path d="M7 13l3.1 2.2" />
    <path d="M13.9 8.8L17 11" />
    <path d="M13.9 15.2L17 13" />
  </svg>
</a>