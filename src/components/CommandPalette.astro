---
// Command palette: barra unificata di ricerca AI-assisted (naviga + cerca contenuti + chiedi all'AI).
// Vanilla JS, zero dipendenze. Lang-aware: link e label localizzati. Indicizza anche gli articoli.
import { getCollection } from 'astro:content';
import { getLangFromUrl, localizePath, entryLang, entrySlug } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const L = (p: string) => localizePath(p, lang);
const en = lang === 'en';
const g = en ? { nav: 'Navigate', act: 'Actions', post: 'Articles' } : { nav: 'Naviga', act: 'Azioni', post: 'Articoli' };

const navCommands = [
  { group: g.nav, name: 'Home', href: L('/'), keys: 'home start', kind: 'nav' },
  { group: g.nav, name: 'CV', href: L('/cv'), keys: 'curriculum cv esperienza experience', kind: 'nav' },
  { group: g.nav, name: 'Projects', sub: en ? 'case files' : 'progetti', href: L('/projects'), keys: 'progetti portfolio case projects work', kind: 'nav' },
  { group: g.nav, name: 'Writing', sub: en ? 'articles' : 'articoli', href: L('/writing'), keys: 'articoli blog post articles', kind: 'nav' },
  { group: g.nav, name: 'Skills', sub: en ? 'technical skills' : 'competenze tecniche', href: L('/skills'), keys: 'competenze skill tecnologie tool skills', kind: 'nav' },
  { group: g.nav, name: 'About', href: L('/about'), keys: 'chi sono bio infra about', kind: 'nav' },
  { group: g.act, name: en ? 'Download CV (PDF)' : 'Scarica il CV (PDF)', href: '/cv.pdf', keys: 'download pdf scarica', kind: 'act' },
  { group: g.act, name: en ? 'Contact' : 'Contatti', href: L('/contact'), keys: 'email scrivi contact contatti', kind: 'act' },
  { group: g.act, name: 'AI Assistant', href: L('/ask'), keys: 'chatbot ai chiedi assistente ask', kind: 'act' },
];

// Indicizza gli articoli (titolo + tag) → ricerca di post e argomenti, non solo pagine.
const posts = (await getCollection('writing', (e) => !e.data.draft && entryLang(e.id) === lang)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const postCommands = posts.map((p) => ({
  group: g.post,
  name: p.data.title,
  href: L(`/writing/${entrySlug(p.id)}`),
  keys: (p.data.tags ?? []).join(' '),
  kind: 'post',
}));

const commands = [...navCommands, ...postCommands];

const i18nStrings = {
  placeholder: en ? 'Search articles, projects, skills… or ask the AI' : 'Cerca articoli, progetti, skill… o chiedi all’AI',
  askGroup: en ? 'Ask the AI' : "Chiedi all'AI",
  noResults: en ? 'No results — try asking the AI.' : "Nessun risultato — prova a chiedere all'AI.",
  askRoute: L('/ask'),
};
---

<div data-cmdk-root class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-label="Command palette">
  <div data-cmdk-overlay class="absolute inset-0 bg-ink-900/70 backdrop-blur-sm"></div>

  <div class="absolute left-1/2 top-[15vh] w-[92vw] max-w-xl -translate-x-1/2 overflow-hidden rounded-lg border border-ink-500 bg-ink-800 shadow-2xl">
    <div class="flex items-center gap-3 border-b border-ink-600 px-4">
      <svg class="h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4.3-4.3"></path>
      </svg>
      <input
        data-cmdk-input
        type="text"
        placeholder={i18nStrings.placeholder}
        class="w-full bg-transparent py-3.5 text-sm text-text placeholder:text-muted focus:outline-none"
        autocomplete="off"
        spellcheck="false"
        aria-label={i18nStrings.placeholder}
      />
      <span class="inline-flex shrink-0 items-center gap-1 rounded-full bg-accent/15 px-1.5 py-0.5 text-accent" title="AI-assisted">
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l1.7 5.6L19 9l-5.3 1.4L12 16l-1.7-5.6L5 9l5.3-1.4L12 2z"></path></svg>
        <span class="font-mono text-[10px] font-semibold tracking-wide">AI</span>
      </span>
      <kbd class="hidden font-mono text-[10px] text-muted sm:block">ESC</kbd>
    </div>

    <ul data-cmdk-list class="max-h-[50vh] overflow-y-auto p-2" role="listbox"></ul>
  </div>
</div>

<script is:inline data-astro-rerun define:vars={{ commands, i18nStrings }}>
  (() => {
    const root = document.querySelector('[data-cmdk-root]');
    if (!root) return;
    const input = root.querySelector('[data-cmdk-input]');
    const list = root.querySelector('[data-cmdk-list]');
    const overlay = root.querySelector('[data-cmdk-overlay]');
    let items = [];
    let active = 0;

    const hasTouchInput = () =>
      (navigator.maxTouchPoints || 0) > 0 ||
      (navigator.msMaxTouchPoints || 0) > 0 ||
      (window.matchMedia && window.matchMedia('(pointer: coarse)').matches);
    const canAutoFocusInput = () =>
      !hasTouchInput() &&
      window.matchMedia &&
      window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    const focusInput = () => {
      if (canAutoFocusInput()) {
        try { input.focus({ preventScroll: true }); } catch (_) {}
      }
    };
    const blurInput = () => { try { input.blur(); } catch (_) {} };

    const open = () => {
      root.classList.remove('hidden');
      input.value = '';
      render('');
      requestAnimationFrame(focusInput);
    };
    const close = () => {
      root.classList.add('hidden');
      blurInput();
    };
    const isOpen = () => !root.classList.contains('hidden');

    function render(q) {
      const query = q.trim().toLowerCase();
      let matches;
      if (!query) {
        // A riposo: solo navigazione + azioni (niente muro di articoli).
        matches = commands.filter((c) => c.kind !== 'post');
      } else {
        const hit = commands.filter((c) => (c.name + ' ' + (c.sub || '') + ' ' + c.keys + ' ' + c.group).toLowerCase().includes(query));
        const postHits = hit.filter((c) => c.kind === 'post').slice(0, 6);
        const others = hit.filter((c) => c.kind !== 'post');
        matches = [...others, ...postHits];
      }

      let html = '';
      let lastGroup = '';
      items = [];

      matches.forEach((c) => {
        if (c.group !== lastGroup) {
          html += `<li class="px-2 pb-1 pt-3 first:pt-1 font-mono text-[10px] uppercase tracking-widest text-muted" aria-hidden="true">${c.group}</li>`;
          lastGroup = c.group;
        }
        const idx = items.length;
        items.push({ type: 'nav', href: c.href });
        const labelHtml = c.sub
          ? `<span class="inline-block w-20 shrink-0">${escapeHtml(c.name)}</span><span class="text-muted">— ${escapeHtml(c.sub)}</span>`
          : `<span>${escapeHtml(c.name)}</span>`;
        html += `<li role="option" data-idx="${idx}" class="cmdk-item flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-sm text-text-dim"><span class="min-w-0 truncate">${labelHtml}</span><span class="ml-3 font-mono text-[10px] text-muted">↵</span></li>`;
      });

      // Sezione "Chiedi all'AI" se c'è una query libera
      if (query) {
        const idx = items.length;
        items.push({ type: 'ask', q: q.trim() });
        html += `<li class="px-2 pb-1 pt-3 font-mono text-[10px] uppercase tracking-widest text-muted" aria-hidden="true">${i18nStrings.askGroup}</li>`;
        html += `<li role="option" data-idx="${idx}" class="cmdk-item flex cursor-pointer items-center justify-between rounded-md px-3 py-2 text-sm text-text-dim"><span>💬 "${escapeHtml(q.trim())}"</span><span class="font-mono text-[10px] text-muted">↵</span></li>`;
      }

      if (items.length === 0) {
        html = `<li class="px-3 py-6 text-center text-sm text-muted">${i18nStrings.noResults}</li>`;
      }

      list.innerHTML = html;
      active = 0;
      highlight();

      list.querySelectorAll('.cmdk-item').forEach((el) => {
        el.addEventListener('mouseenter', () => { active = Number(el.dataset.idx); highlight(); });
        el.addEventListener('click', () => exec(Number(el.dataset.idx)));
      });
    }

    function highlight() {
      list.querySelectorAll('.cmdk-item').forEach((el) => {
        const on = Number(el.dataset.idx) === active;
        el.classList.toggle('bg-ink-600', on);
        el.classList.toggle('text-text', on);
        if (on) el.scrollIntoView({ block: 'nearest' });
      });
    }

    function exec(idx) {
      const it = items[idx];
      if (!it) return;
      if (it.type === 'ask') {
        window.location.href = i18nStrings.askRoute + '?q=' + encodeURIComponent(it.q);
      } else {
        window.location.href = it.href;
      }
    }

    function escapeHtml(s) {
      return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    input.addEventListener('input', (e) => render(e.target.value));
    overlay.addEventListener('click', close);

    // Listener su document idempotenti: rimuovo i precedenti (utile con le View Transitions).
    const onKey = (e) => {
      const mod = e.metaKey || e.ctrlKey;
      if (mod && e.key.toLowerCase() === 'k') { e.preventDefault(); isOpen() ? close() : open(); return; }
      if (!isOpen()) return;
      if (e.key === 'Escape') { e.preventDefault(); close(); }
      else if (e.key === 'ArrowDown') { e.preventDefault(); active = Math.min(active + 1, items.length - 1); highlight(); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); active = Math.max(active - 1, 0); highlight(); }
      else if (e.key === 'Enter') { e.preventDefault(); exec(active); }
    };
    const onClick = (e) => { if (e.target.closest('[data-cmdk-open]')) open(); };

    if (window.__cmdkKey) document.removeEventListener('keydown', window.__cmdkKey);
    if (window.__cmdkClick) document.removeEventListener('click', window.__cmdkClick);
    document.addEventListener('keydown', onKey);
    document.addEventListener('click', onClick);
    window.__cmdkKey = onKey;
    window.__cmdkClick = onClick;
  })();
</script>
