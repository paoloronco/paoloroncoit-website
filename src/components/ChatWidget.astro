---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const i18n = {
  searching: t('chat.searching'),
  found: t('chat.found'),
  empty: t('chat.empty'),
  error: t('chat.error'),
};
---

<!-- Bolla (FAB) -->
<button
  type="button"
  data-chat-toggle
  aria-label={t('chat.open')}
  aria-expanded="false"
  class="chat-fab group fixed bottom-5 right-5 z-40 flex h-14 w-14 items-center justify-center rounded-full text-ink-900 transition-transform hover:scale-105 active:scale-95"
>
  <svg data-chat-icon-open width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7a8.5 8.5 0 0 1-.9-3.8A8.38 8.38 0 0 1 12.5 3a8.38 8.38 0 0 1 8.5 8.5z"/>
    <circle cx="8.5" cy="11.5" r="0.6" fill="currentColor"/><circle cx="12.5" cy="11.5" r="0.6" fill="currentColor"/><circle cx="16.5" cy="11.5" r="0.6" fill="currentColor"/>
  </svg>
  <svg data-chat-icon-close class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
</button>

<!-- Pannello chat -->
<section
  data-chat-panel
  role="dialog"
  aria-label={t('ask.title')}
  class="chat-panel fixed bottom-24 right-5 z-40 flex w-[min(92vw,380px)] flex-col overflow-hidden rounded-2xl border border-ink-500 bg-ink-800/95 shadow-2xl backdrop-blur-md"
  style="max-height:min(70vh,560px)"
>
  <header class="flex items-center gap-3 border-b border-ink-600 px-4 py-3">
    <span class="chat-fab flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-ink-900">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7a8.5 8.5 0 0 1-.9-3.8A8.38 8.38 0 0 1 12.5 3a8.38 8.38 0 0 1 8.5 8.5z"/></svg>
    </span>
    <div class="min-w-0 flex-1">
      <p class="text-sm font-semibold text-text">{t('ask.title')}</p>
      <p class="flex items-center gap-1.5 font-mono text-[10px] text-muted">
        <span class="h-1.5 w-1.5 rounded-full bg-ok"></span>{t('chat.tagline')}
      </p>
    </div>
    <button type="button" data-chat-close aria-label="×" class="rounded-md p-1 text-muted transition-colors hover:text-text">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
    </button>
  </header>

  <div data-chatw-log class="flex-1 space-y-3 overflow-y-auto p-4 text-sm">
    <div><span class="inline-block max-w-[85%] rounded-2xl rounded-bl-sm bg-ink-700 px-3 py-2 text-text-dim">{t('chat.greeting')}</span></div>
  </div>

  <form data-chatw-form class="flex items-center gap-2 border-t border-ink-600 p-3">
    <input
      data-chatw-input
      type="text"
      placeholder={t('ask.placeholder')}
      class="w-full rounded-lg bg-ink-900/60 px-3 py-2.5 text-sm text-text placeholder:text-muted focus:outline-none focus:ring-1 focus:ring-accent"
      autocomplete="off"
    />
    <button type="submit" aria-label={t('ask.send')} class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-accent text-ink-900 transition-opacity hover:opacity-90">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
    </button>
  </form>
</section>

<script is:inline data-astro-rerun define:vars={{ i18n }}>
  (() => {
    const fab = document.querySelector('[data-chat-toggle]');
    const panel = document.querySelector('[data-chat-panel]');
    if (!fab || !panel) return;
    const log = panel.querySelector('[data-chatw-log]');
    const form = panel.querySelector('[data-chatw-form]');
    const input = panel.querySelector('[data-chatw-input]');
    const iOpen = fab.querySelector('[data-chat-icon-open]');
    const iClose = fab.querySelector('[data-chat-icon-close]');
    const closeBtn = panel.querySelector('[data-chat-close]');
    let busy = false;

    const hasTouchInput = () =>
      (navigator.maxTouchPoints || 0) > 0 ||
      (navigator.msMaxTouchPoints || 0) > 0 ||
      (window.matchMedia && window.matchMedia('(pointer: coarse)').matches);
    const canAutoFocusInput = () =>
      !hasTouchInput() &&
      window.matchMedia &&
      window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    const focusInput = () => {
      if (canAutoFocusInput()) {
        try { input && input.focus({ preventScroll: true }); } catch (_) {}
      }
    };
    const blurInput = () => { try { input && input.blur(); } catch (_) {} };

    const setCookieOffset = () => {
      const viewportBottom = window.innerHeight;
      let offset = 0;
      document.querySelectorAll('.cky-consent-container, [class*="cky-consent"]').forEach((el) => {
        const style = window.getComputedStyle(el);
        const rect = el.getBoundingClientRect();
        if (style.display === 'none' || style.visibility === 'hidden' || Number(style.opacity) === 0) return;
        if (rect.width < 180 || rect.height < 40 || rect.bottom < viewportBottom - 16) return;
        offset = Math.max(offset, Math.min(rect.height + 12, viewportBottom * 0.45));
      });
      document.documentElement.style.setProperty('--chat-cookie-offset', offset ? `${Math.round(offset)}px` : '0px');
    };

    if (window.__chatCookieObserver) window.__chatCookieObserver.disconnect();
    if (window.__chatCookieResize) window.removeEventListener('resize', window.__chatCookieResize);
    const cookieObserver = new MutationObserver(setCookieOffset);
    cookieObserver.observe(document.body, { childList: true, subtree: true, attributes: true, attributeFilter: ['class', 'style'] });
    window.addEventListener('resize', setCookieOffset);
    window.__chatCookieObserver = cookieObserver;
    window.__chatCookieResize = setCookieOffset;
    setCookieOffset();
    setTimeout(setCookieOffset, 500);
    setTimeout(setCookieOffset, 1500);

    // sessionId persistente per la sessione del browser (continuità conversazione)
    let sid;
    try {
      sid = sessionStorage.getItem('chatSid');
      if (!sid) { sid = 'web-' + Date.now().toString(36) + Math.random().toString(36).slice(2, 8); sessionStorage.setItem('chatSid', sid); }
    } catch (e) { sid = 'web-' + Date.now(); }

    const setOpen = (v) => {
      panel.classList.toggle('is-open', v);
      fab.setAttribute('aria-expanded', v ? 'true' : 'false');
      iOpen && iOpen.classList.toggle('hidden', v);
      iClose && iClose.classList.toggle('hidden', !v);
      if (v) requestAnimationFrame(focusInput);
      else blurInput();
    };

    const scroll = () => { log.scrollTop = log.scrollHeight; };
    const escHtml = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const fmt = (s) => escHtml(s).replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>');

    const bubble = (who, text) => {
      const wrap = document.createElement('div');
      wrap.className = who === 'me' ? 'text-right' : '';
      const span = document.createElement('span');
      span.className =
        'inline-block max-w-[85%] rounded-2xl px-3 py-2 ' +
        (who === 'me' ? 'rounded-br-sm bg-accent text-ink-900' : 'rounded-bl-sm bg-ink-700 text-text-dim');
      span.textContent = text;
      wrap.appendChild(span);
      log.appendChild(wrap);
      scroll();
    };

    const typing = () => {
      const wrap = document.createElement('div');
      const span = document.createElement('span');
      span.className = 'inline-block rounded-2xl rounded-bl-sm bg-ink-700 px-3 py-2.5';
      span.innerHTML = '<span class="typing-dots"><span></span><span></span><span></span></span>';
      wrap.appendChild(span);
      log.appendChild(wrap);
      scroll();
      return wrap;
    };

    const renderResults = (data) => {
      const wrap = document.createElement('div');
      wrap.className = 'space-y-2';
      const intro = document.createElement('p');
      intro.className = 'text-xs text-muted';
      intro.textContent = i18n.found;
      wrap.appendChild(intro);
      (data.results || []).forEach((r) => {
        const hasUrl = r && r.url && r.url !== '#';
        const el = document.createElement(hasUrl ? 'a' : 'div');
        el.className = 'chat-card';
        if (hasUrl) { el.href = r.url; el.target = '_blank'; el.rel = 'noopener'; }
        el.innerHTML = '<span class="chat-card__title"></span><span class="chat-card__body"></span>';
        el.querySelector('.chat-card__title').textContent = (r && r.title) || '';
        el.querySelector('.chat-card__body').innerHTML = fmt(r && r.summary);
        wrap.appendChild(el);
      });
      log.appendChild(wrap);
      scroll();
    };

    const render = (data) => {
      if (data && data.type === 'search_results') {
        if (!data.results || !data.results.length) return bubble('ai', i18n.empty);
        return renderResults(data);
      }
      const text = data && (data.reply || data.output || data.message || data.answer || data.text);
      bubble('ai', text || i18n.empty);
    };

    const send = async (q) => {
      if (!q || busy) return;
      busy = true;
      bubble('me', q);
      const t = typing();
      try {
        const r = await fetch('/api/ask', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: q, sessionId: sid }),
        });
        const data = await r.json().catch(() => null);
        t.remove();
        if (!r.ok || !data) bubble('ai', i18n.error);
        else render(data);
      } catch (e) {
        t.remove();
        bubble('ai', i18n.error);
      } finally {
        busy = false;
        scroll();
      }
    };

    fab.addEventListener('click', () => setOpen(!panel.classList.contains('is-open')));
    closeBtn && closeBtn.addEventListener('click', () => setOpen(false));
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      input.value = '';
      send(q);
    });

    // Esc per chiudere (idempotente con le View Transitions)
    if (window.__chatEsc) document.removeEventListener('keydown', window.__chatEsc);
    const onEsc = (e) => { if (e.key === 'Escape') setOpen(false); };
    document.addEventListener('keydown', onEsc);
    window.__chatEsc = onEsc;
  })();
</script>