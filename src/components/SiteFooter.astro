---
import { site } from '@/data/site';
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
const networkLinks = [
  { label: 'OrbitPage', detail: 'orbitpage.paoloronco.it', href: 'https://orbitpage.paoloronco.it/', tone: 'orbitpage' },
  { label: 'DarkWeb', detail: 'darkweb.paoloronco.it', href: 'https://darkweb.paoloronco.it/', tone: 'darkweb' },
  { label: 'Shop', detail: 'shop.paoloronco.it', href: 'https://shop.paoloronco.it/', tone: 'shop' },
  { label: 'Academy', detail: 'nextprep.academy', href: 'https://www.nextprep.academy/', tone: 'academy' },
  {
    label: 'TabSessionSaver',
    detail: 'Chrome extension',
    href: 'https://tabsessionsaver.paoloronco.it/',
    tone: 'extension',
  },
] as const;
---

<footer id="site-footer" class="mt-24 border-t border-ink-600/70">
  <div class="mx-auto flex max-w-5xl flex-col gap-4 px-5 py-10 text-sm text-muted sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="font-mono text-text">{site.name}</p>
      <p class="mt-1">{site.role}</p>
      <p class="mt-1">{site.domains.join(' · ')}</p>
    </div>
    <div class="flex w-full flex-col items-start gap-3 text-[13px] sm:w-auto sm:items-end sm:text-sm">
      <nav class="footer-network" aria-label="Paolo Ronco network">
        {
          networkLinks.map((link) => (
            <a
              class={`footer-network__link footer-network__link--${link.tone}`}
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              title={link.detail}
              aria-label={`${link.label}: ${link.detail}`}
            >
              <span class="footer-network__name">{link.label}</span>
            </a>
          ))
        }
      </nav>
      <nav class="flex w-full flex-nowrap items-center justify-between gap-3 sm:w-auto sm:justify-start sm:gap-x-5" aria-label="Social links">
        <a class="hover:text-accent" href={site.socials.github}>GitHub</a>
        <a class="hover:text-accent" href={site.socials.huggingface} aria-label="Hugging Face">
          <span class="sm:hidden">HF</span><span class="hidden sm:inline">Hugging Face</span>
        </a>
        <a class="hover:text-accent" href={site.socials.linkedin}>LinkedIn</a>
        <a class="hover:text-accent" href="/rss.xml">RSS</a>
      </nav>
      <nav class="flex w-full flex-nowrap items-center justify-between gap-3 font-mono text-xs text-muted/75 sm:w-auto sm:justify-start sm:gap-x-4" aria-label="Machine-readable files">
        <a class="hover:text-accent" href="/llm.txt">llm.txt</a>
        <a class="hover:text-accent" href="/.well-known/security.txt">security.txt</a>
        <a class="hover:text-accent" href="/robots.txt">robots.txt</a>
      </nav>
    </div>
  </div>

  <!-- Open source repo box -->
  <div class="mx-auto max-w-5xl px-5 pb-6">
    <a
      href={site.socials.repo}
      target="_blank"
      rel="noopener noreferrer"
      class="group flex items-center gap-3 rounded-lg border border-ink-600/70 bg-ink-800/60 px-4 py-3 text-sm text-muted transition-all hover:border-accent/40 hover:bg-ink-700/60 hover:text-text sm:w-fit"
      aria-label="View source on GitHub"
    >
      <svg class="h-5 w-5 shrink-0 text-muted transition-colors group-hover:text-accent" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
      </svg>
      <div class="min-w-0">
        <p class="font-mono text-xs font-medium leading-tight text-text transition-colors group-hover:text-accent">
          paoloronco / paoloroncoit-website
        </p>
        <p class="mt-0.5 text-xs text-muted/70">
          {lang === 'en' ? 'Open source · Astro · Tailwind · Vercel' : 'Open source · Astro · Tailwind · Vercel'}
        </p>
      </div>
      <svg class="ml-auto h-3.5 w-3.5 shrink-0 opacity-0 transition-all group-hover:translate-x-0.5 group-hover:opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M7 17 17 7M7 7h10v10"/>
      </svg>
    </a>
  </div>

  <div class="mx-auto flex max-w-5xl flex-col gap-3 px-5 pb-28 sm:flex-row sm:items-center sm:justify-between sm:pb-8">
    <p class="font-mono text-xs text-muted/70">© {year} {site.name}</p>
    <nav class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-muted" aria-label={t('footer.legal')}>
      <a class="hover:text-accent" href={localizePath('/privacy', lang)}>{t('footer.privacy')}</a>
      <span class="text-ink-600" aria-hidden="true">·</span>
      <a class="hover:text-accent" href={localizePath('/terms', lang)}>{t('footer.terms')}</a>
      <span class="text-ink-600" aria-hidden="true">·</span>
      <a class="hover:text-accent" href={localizePath('/cookie', lang)}>{t('footer.cookie')}</a>
    </nav>
  </div>
</footer>

<style>
  .footer-network {
    display: flex;
    width: 100%;
    max-width: 100%;
    align-items: center;
    gap: clamp(0.35rem, 1.4vw, 1.05rem);
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.1rem 0 0.2rem;
    scrollbar-width: none;
  }

  .footer-network::-webkit-scrollbar {
    display: none;
  }

  .footer-network__link {
    --network-color: var(--color-accent);
    position: relative;
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 0.25rem;
    padding: 0.1rem 0;
    color: var(--color-text-dim);
    white-space: nowrap;
    transition:
      color 0.2s var(--ease-out-quart),
      transform 0.2s var(--ease-out-quart);
  }

  .footer-network__link::before {
    content: '';
    width: 0.28rem;
    height: 0.28rem;
    flex: 0 0 auto;
    border-radius: 9999px;
    background: var(--network-color);
    opacity: 0.72;
    box-shadow: 0 0 0 2px color-mix(in oklab, var(--network-color) 14%, transparent);
  }

  .footer-network__link:hover {
    color: var(--network-color);
    transform: translateY(-1px);
  }

  .footer-network__name {
    font-family: var(--font-display);
    font-size: clamp(0.67rem, 2.35vw, 0.82rem);
    font-weight: 650;
    line-height: 1;
    letter-spacing: 0;
  }

  .footer-network__link--orbitpage {
    --network-color: var(--color-cat-tool);
  }

  .footer-network__link--darkweb {
    --network-color: var(--color-cat-security);
  }

  .footer-network__link--shop {
    --network-color: var(--color-cat-automation);
  }

  .footer-network__link--academy {
    --network-color: var(--color-cat-ai);
  }

  .footer-network__link--extension {
    --network-color: var(--color-cat-cloud);
  }

  @media (min-width: 640px) {
    .footer-network {
      width: auto;
      max-width: none;
      flex-wrap: nowrap;
      justify-content: flex-end;
      overflow: visible;
      gap: 1.05rem;
    }

    .footer-network__link {
      gap: 0.38rem;
    }

    .footer-network__link::before {
      width: 0.34rem;
      height: 0.34rem;
    }
  }
</style>
