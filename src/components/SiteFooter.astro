---
import { site } from '@/data/site';
import { getLangFromUrl, useTranslations, localizePath } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="mt-0 bg-ink text-paper">
  <div class="field-shell py-16 sm:py-24">
    <p class="field-label">{lang === 'en' ? '05 / Contact' : '05 / Contatto'}</p>
    <a href={`mailto:${site.email}`} class="group mt-8 block font-display text-[clamp(3.5rem,10vw,9rem)] font-semibold leading-[.78] tracking-[-.08em]">
      {lang === 'en' ? 'OPEN A' : 'APRI UN'}<br /><span class="field-serif text-signal group-hover:text-paper">{lang === 'en' ? 'CHANNEL.' : 'CANALE.'}</span>
    </a>
    <div class="mt-16 grid gap-8 border-t border-paper/40 pt-6 font-mono text-[10px] uppercase tracking-[.08em] sm:grid-cols-3">
      <div><p class="text-paper/50">Direct</p><a class="mt-2 inline-block hover:text-signal" href={`mailto:${site.email}`}>{site.email}</a></div>
      <div class="flex flex-wrap content-start gap-x-4 gap-y-2"><a class="hover:text-signal" href={site.socials.github}>GitHub</a><a class="hover:text-signal" href={site.socials.linkedin}>LinkedIn</a><a class="hover:text-signal" href={site.socials.huggingface}>Hugging Face</a><a class="hover:text-signal" href="/rss.xml">RSS</a></div>
      <div class="sm:text-right"><p>© {year} {site.name}</p><nav class="mt-2 flex gap-3 sm:justify-end" aria-label={t('footer.legal')}><a href={localizePath('/privacy', lang)}>{t('footer.privacy')}</a><a href={localizePath('/terms', lang)}>{t('footer.terms')}</a><a href={localizePath('/cookie', lang)}>{t('footer.cookie')}</a></nav></div>
    </div>
  </div>
</footer>
