---
import { site } from '@/data/site';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-ink-600/70">
  <div class="mx-auto flex max-w-5xl flex-col gap-4 px-5 py-10 text-sm text-muted sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="font-mono text-text">{site.name}</p>
      <p class="mt-1">{site.role} · {site.domains.join(' · ')}</p>
    </div>
    <div class="flex flex-wrap gap-x-5 gap-y-2">
      <a class="hover:text-accent" href={site.socials.github}>GitHub</a>
      <a class="hover:text-accent" href={site.socials.huggingface}>Hugging Face</a>
      <a class="hover:text-accent" href={site.socials.linkedin}>LinkedIn</a>
      <a class="hover:text-accent" href="/rss.xml">RSS</a>
      <a class="hover:text-accent" href="/.well-known/security.txt">security.txt</a>
    </div>
  </div>
  <div class="mx-auto max-w-5xl px-5 pb-8">
    <p class="font-mono text-xs text-muted/70">© {year} · {t('footer.rights')}</p>
  </div>
</footer>
