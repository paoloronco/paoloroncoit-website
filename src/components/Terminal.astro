---
// Terminale interattivo dell'hero. Tutto lato client (nessuna VM/container):
// l'intro si "scrive" da sola, poi l'utente digita comandi reali con risposte.
// I comandi sconosciuti restituiscono un errore "command not found".
import { enterpriseSecurityArea, site } from '@/data/site';
import { getCollection } from 'astro:content';
import { entryLang, entrySlug, getLangFromUrl, localizePath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const en = lang === 'en';
const user = 'paolo';
const host = 'secops';
const path = '~';

const focus: [string, string][] = [
  ['security', 'security architecture · cloud security · zero trust · IAM · CSPM/CNAPP · SIEM/SOAR · EDR/XDR · risk & compliance'],
  ['ai', en ? 'RAG · agents · self-hosted LLMs · Heretic · AI red teaming · MCP' : 'RAG · agenti · LLM self-hosted · Heretic · AI red teaming · MCP'],
  ['automation', 'workflow · pipeline · REST API · CI/CD · n8n · Zapier · Make · GitHub Actions · serverless'],
  ['cloud', 'Google Cloud · AWS · Azure · Oracle Cloud · IaaS/PaaS/SaaS'],
];

const projectEntries = (await getCollection('work', (entry) => !entry.data.draft && entryLang(entry.id) === lang)).sort(
  (a, b) => a.data.order - b.data.order
);

const projectFiles = projectEntries.map((project) => {
  const slug = entrySlug(project.id).replace(/\/index$/, '');
  const filename = `${slug.replace(/[^a-zA-Z0-9._-]+/g, '-')}.md`;
  const data = project.data;
  const body = typeof project.body === 'string' && project.body.trim() ? project.body.trim() : '';
  const lines = [
    `# ${data.title}`,
    '',
    data.summary,
    '',
    `category: ${data.category}`,
    `stack: ${data.stack.join(', ') || '-'}`,
    '',
    `## ${en ? 'Problem' : 'Problema'}`,
    data.problem,
    '',
    `## ${en ? 'Solution' : 'Soluzione'}`,
    data.solution,
    '',
    `## ${en ? 'Outcome' : 'Risultato'}`,
    data.outcome,
  ];
  if (data.links.length) {
    lines.push(
      '',
      `## Link`,
      ...data.links.map((item) => `- [${item.label}](${item.href})`)
    );
  }
  if (body) lines.push('', '---', '', body);
  return { filename, markdown: lines.join('\n'), href: localizePath(`/work/${slug}`, lang) };
});

const T = {
  user, host, path,
  lang,
  role: `Cyber Security Analyst · Deloitte · ${enterpriseSecurityArea}`,
  email: site.email,
  cvpdf: '/cv.pdf',
  focus,
  links: { GitHub: site.socials.github, LinkedIn: site.socials.linkedin, 'Hugging Face': site.socials.huggingface },
  paths: {
    cv: localizePath('/cv', lang),
    work: localizePath('/work', lang),
    writing: localizePath('/writing', lang),
    skills: localizePath('/skills', lang),
    about: localizePath('/about', lang),
    ask: localizePath('/ask', lang),
    contact: localizePath('/contact', lang),
  },
  endpoints: {
    writings: `/api/terminal/writings.json?lang=${lang}`,
  },
  s: {
    dHelp: en ? 'list the available commands' : "elenca i comandi disponibili",
    dWhoami: en ? 'who I am, in one line' : 'chi sono, in una riga',
    dSkills: en ? 'technical skills (with levels)' : 'competenze tecniche (con livelli)',
    dWork: en ? 'projects / case files' : 'progetti / case file',
    dWriting: en ? 'articles & notes' : 'articoli e note',
    dCv: en ? 'experience, certifications, education' : 'esperienza, certificazioni, formazione',
    dAbout: en ? 'who I am' : 'chi sono',
    dContact: en ? 'how to reach me' : 'come contattarmi',
    dAi: en ? 'ask the AI assistant' : "chiedi all'assistente AI",
    dSocial: en ? 'my profiles' : 'i miei profili',
    dFocus: en ? 'focus areas' : 'aree di competenza',
    dClear: en ? 'clear the terminal' : 'pulisci il terminale',
    dCd: en ? 'change directory' : 'entra/esci da una cartella',
    dLs: en ? 'list files in the current directory' : 'lista i file nella cartella corrente',
    dCat: en ? 'read a file (e.g. cat cv.md)' : 'leggi un file (es. cat cv.md)',
    notFound: en ? 'command not found' : 'comando non trovato',
    hint: en ? "type 'help' to list the commands" : "scrivi 'help' per l'elenco dei comandi",
    introHint: en ? "interactive terminal — type 'help' and press enter" : "terminale interattivo — scrivi 'help' e premi invio",
    placeholder: en ? 'type a command… (e.g. help)' : 'scrivi un comando… (es. help)',
    noFile: en ? 'No such file or directory' : 'file o cartella inesistente',
    isDir: en ? 'Is a directory' : 'è una cartella',
    emptyProjects: en ? 'no project markdown files yet' : 'nessun file markdown progetto al momento',
    emptyWritings: en ? 'no article markdown files yet' : 'nessun file markdown articolo al momento',
    badPath: en ? 'invalid path' : 'percorso non valido',
    loadError: en ? 'unable to load files' : 'impossibile caricare i file',
    readonly: en ? '(read-only — this is a terminal, not an editor 🙂)' : '(sola lettura — è un terminale, non un editor 🙂)',
    bio: en
      ? `Cyber Security Analyst at Deloitte, in the ${enterpriseSecurityArea}. Cloud security, infrastructure and AI applied to defense.`
      : `Cyber Security Analyst in Deloitte, nell'${enterpriseSecurityArea}. Sicurezza cloud, infrastrutture e AI applicata alla difesa.`,
    sudo: en ? '🔒 no root here — it all runs in your browser.' : '🔒 niente root qui — gira tutto nel tuo browser.',
    nmap: en ? 'scanning… 1 host up: you. only open port: curiosity.' : 'scanning… 1 host up: tu. unica porta aperta: la curiosità.',
    hack: en ? 'the only hack here is how fast this site loads ⚡' : "l'unico hack qui è quanto è veloce questo sito ⚡",
    aria: en ? 'Interactive terminal input' : 'Input del terminale interattivo',
    close: en ? 'close terminal' : 'chiudi terminale',
    minimize: en ? 'minimize terminal' : 'minimizza terminale',
    maximize: en ? 'expand terminal' : 'espandi terminale',
    restore: en ? 'restore terminal' : 'ripristina terminale',
    reopen: en ? 'reopen terminal' : 'riapri terminale',
  },
  projectFiles,
};
---
<div class="term-shell" data-term-shell>
  <div class="term" data-term>
    <div class="term__bar">
      <button class="term__dot term__dot--close" style="background:#fb7185" type="button" data-term-action="close" aria-label={T.s.close} title={T.s.close}></button>
      <button class="term__dot term__dot--minimize" style="background:#fbbf24" type="button" data-term-action="minimize" aria-label={T.s.minimize} title={T.s.minimize}></button>
      <button class="term__dot term__dot--maximize" style="background:#34d399" type="button" data-term-action="maximize" aria-label={T.s.maximize} title={T.s.maximize}></button>
      <span class="term__title">{user}@{host} — zsh</span>
    </div>
    <div class="term__body" data-term-body>
      <div data-term-log></div>
      <div class="term__line term__inputline" data-term-inputline hidden>
        <span class="term__promptwrap"><span class="term__user">{user}@{host}</span><span class="term__muted">:</span><span class="term__path">{path}</span><span class="term__prompt"> # </span></span>
        <input
          class="term__field"
          data-term-input
          type="text"
          autocomplete="off"
          autocapitalize="off"
          autocorrect="off"
          spellcheck="false"
          aria-label={T.s.aria}
          placeholder={T.s.placeholder}
        />
      </div>
    </div>
  </div>
  <button class="term-notch" type="button" data-term-reopen hidden aria-label={T.s.reopen} title={T.s.reopen}>
    <span class="term-notch__light"></span>
    <span class="term-notch__label">{user}@{host}</span>
  </button>
</div>

<script is:inline data-astro-rerun define:vars={{ T }}>
  (() => {
    function initTerms() {
      document.querySelectorAll('[data-term]').forEach((term) => {
        if (term.dataset.ready) return;
        term.dataset.ready = '1';
        setup(term);
      });
    }

    function setup(term) {
      const shell = term.closest('[data-term-shell]');
      const body = term.querySelector('[data-term-body]');
      const log = term.querySelector('[data-term-log]');
      const inputline = term.querySelector('[data-term-inputline]');
      const input = term.querySelector('[data-term-input]');
      const reopen = shell && shell.querySelector('[data-term-reopen]');
      const maximizeBtn = term.querySelector('[data-term-action="maximize"]');
      const history = [];
      let hi = 0;
      let shellHome = null;
      let cwdKey = 'root';
      let writingsDir = null;
      let commandQueue = Promise.resolve();

      const esc = (s) => String(s == null ? '' : s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
      const cwdPath = () => cwdKey === 'root' ? '~' : `~/${cwdKey}/`;
      const promptHtml = () =>
        `<span class="term__promptwrap"><span class="term__user">${esc(T.user)}@${esc(T.host)}</span><span class="term__muted">:</span>` +
        `<span class="term__path">${esc(cwdPath())}</span><span class="term__prompt"> # </span></span>`;
      const scroll = () => { body.scrollTop = body.scrollHeight; };
      const hasTouchInput = () =>
        (navigator.maxTouchPoints || 0) > 0 ||
        (navigator.msMaxTouchPoints || 0) > 0 ||
        (window.matchMedia && window.matchMedia('(pointer: coarse)').matches);
      const canAutoFocusInput = () =>
        !hasTouchInput() &&
        window.matchMedia &&
        window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      const focusInput = () => {
        if (!inputline.hidden && canAutoFocusInput()) {
          try { input.focus({ preventScroll: true }); } catch (_) {}
        }
      };
      const moveShellToViewport = () => {
        if (!shell || shellHome) return;
        shellHome = document.createComment('terminal-home');
        shell.parentNode.insertBefore(shellHome, shell);
        document.body.appendChild(shell);
      };
      const moveShellHome = () => {
        if (!shell || !shellHome || !shellHome.parentNode) return;
        shellHome.parentNode.insertBefore(shell, shellHome);
        shellHome.remove();
        shellHome = null;
      };
      const setMaximized = (on) => {
        if (!shell) return;
        if (on) moveShellToViewport();
        shell.classList.toggle('is-maximized', on);
        if (maximizeBtn) {
          maximizeBtn.setAttribute('aria-label', on ? T.s.restore : T.s.maximize);
          maximizeBtn.setAttribute('title', on ? T.s.restore : T.s.maximize);
        }
        scroll();
        if (on) focusInput();
        else moveShellHome();
      };
      const setMinimized = (on) => {
        if (!shell || !reopen) return;
        if (on) {
          setMaximized(false);
          try { input.blur(); } catch (_) {}
        }
        shell.classList.toggle('is-minimized', on);
        reopen.hidden = !on;
      };

      function addLine(html, cls) {
        const div = document.createElement('div');
        div.className = 'term__line' + (cls ? ' ' + cls : '');
        div.innerHTML = html;
        log.appendChild(div);
        scroll();
        return div;
      }

      const link = (href, label) => `<a class="term__link" href="${esc(href)}">${esc(label || href)}</a>`;
      const navOut = (key, desc) => `<span class="term__resp">${esc(desc)}</span>\n<span class="term__muted">→</span> ${link(T.paths[key], T.paths[key])}`;
      const go = (href) => { window.location.href = href; };
      const projectDir = {
        empty: T.s.emptyProjects,
        href: T.paths.work,
        map: Object.fromEntries((T.projectFiles || []).map((file) => [file.filename, file])),
        names: (T.projectFiles || []).map((file) => file.filename),
      };
      const rootDirs = {
        projects: projectDir,
        writings: null,
      };
      const dirAliases = {
        projects: 'projects',
        project: 'projects',
        work: 'projects',
        writing: 'writings',
        writings: 'writings',
        articles: 'writings',
        blog: 'writings',
      };
      const safeArg = (arg) => {
        const raw = (arg || '').trim().replace(/^~\//, '').replace(/^\.\//, '').replace(/\/+$/, '');
        if (!raw) return '';
        if (raw.includes('\0') || raw.includes('\\')) return null;
        const parts = raw.split('/').filter(Boolean);
        if (parts.some((part) => part === '.' || part === '..')) return null;
        return parts.join('/');
      };
      const validFile = (file) =>
        file &&
        typeof file.filename === 'string' &&
        /^[a-zA-Z0-9._-]+\.md$/.test(file.filename) &&
        typeof file.markdown === 'string' &&
        typeof file.href === 'string';
      const loadWritings = async () => {
        if (writingsDir) return writingsDir;
        const response = await fetch(T.endpoints.writings, { credentials: 'same-origin' });
        if (!response.ok) throw new Error(T.s.loadError);
        const data = await response.json();
        const files = Array.isArray(data.files) ? data.files.filter(validFile) : [];
        writingsDir = {
          empty: T.s.emptyWritings,
          href: T.paths.writing,
          map: Object.fromEntries(files.map((file) => [file.filename, file])),
          names: files.map((file) => file.filename),
        };
        rootDirs.writings = writingsDir;
        return writingsDir;
      };
      const getDir = async (key) => key === 'writings' ? loadWritings() : rootDirs[key];
      const listDir = async (key) => {
        const dir = await getDir(key);
        if (!dir || !dir.names.length) return `<span class="term__muted">${esc((dir && dir.empty) || T.s.noFile)}</span>`;
        return `<span class="term__path">${dir.names.map(esc).join('  ')}</span>`;
      };
      const dirKeyFromPath = (path) => dirAliases[path] || '';

      const helpList = [
        ['help', T.s.dHelp], ['whoami', T.s.dWhoami], ['skills', T.s.dSkills], ['projects', T.s.dWork],
        ['articles', T.s.dWriting], ['cv', T.s.dCv], ['about', T.s.dAbout], ['contact', T.s.dContact],
        ['ai', T.s.dAi], ['social', T.s.dSocial], ['focus', T.s.dFocus], ['cd', T.s.dCd],
        ['ls', T.s.dLs], ['cat', T.s.dCat], ['clear', T.s.dClear],
      ];

      const commands = {
        help: () => helpList.map(([c, d]) => `<span class="term__key">${c.padEnd(9)}</span><span class="term__muted">${esc(d)}</span>`).join('\n'),
        whoami: () => `<span class="term__resp">${esc(T.role)}</span>`,
        focus: () => T.focus.map(([k, d]) => `<span class="term__key">${k.padEnd(12)}</span><span class="term__resp">${esc(d)}</span>`).join('\n'),
        about: () => navOut('about', T.s.dAbout),
        skills: () => navOut('skills', T.s.dSkills),
        work: () => navOut('work', T.s.dWork),
        projects: async () => { cwdKey = 'projects'; return commands.ls(); },
        writing: async () => { cwdKey = 'writings'; return commands.ls(); },
        writings: async () => commands.writing(),
        articles: () => commands.writing(),
        blog: () => commands.writing(),
        cv: () => `<span class="term__resp">${esc(T.s.dCv)}</span>\n<span class="term__muted">→</span> ${link(T.paths.cv, T.paths.cv)}  <span class="term__muted">·</span>  ${link(T.cvpdf, 'cv.pdf ↓')}`,
        resume: () => commands.cv(),
        contact: () => `<span class="term__resp">${esc(T.s.dContact)}</span>\n<span class="term__muted">→</span> ${link('mailto:' + T.email, T.email)}`,
        email: () => commands.contact(),
        social: () => Object.keys(T.links).map((k) => `<span class="term__key">${k.padEnd(14)}</span>${link(T.links[k], T.links[k])}`).join('\n'),
        pwd: () => `<span class="term__resp">${esc(cwdPath())}</span>`,
        cd: async (arg) => {
          const target = (arg || '').trim().replace(/\/+$/, '');
          if (!target || target === '~') { cwdKey = 'root'; return null; }
          if (target === '..') { cwdKey = 'root'; return null; }
          if (target === '.') return null;
          const clean = safeArg(target);
          if (clean == null) return `<span class="term__err">cd: ${esc(arg)}: ${esc(T.s.badPath)}</span>`;
          const next = dirKeyFromPath(clean);
          if (next) {
            cwdKey = next;
            if (next === 'writings') await loadWritings();
            return null;
          }
          return `<span class="term__err">cd: ${esc(arg)}: ${esc(T.s.noFile)}</span>`;
        },
        ls: async (arg) => {
          const target = safeArg(arg);
          if (target == null) return `<span class="term__err">ls: ${esc(arg)}: ${esc(T.s.badPath)}</span>`;
          if (!target) return cwdKey === 'root' ? `<span class="term__path">cv.md  skills.json  projects/  writings/  about.md  contact.md  focus.txt</span>` : listDir(cwdKey);
          const key = dirKeyFromPath(target);
          if (key) return listDir(key);
          return `<span class="term__err">ls: ${esc(arg)}: ${esc(T.s.noFile)}</span>`;
        },
        ai: (arg) => { if (arg) { go(T.paths.ask + '?q=' + encodeURIComponent(arg)); return null; } return navOut('ask', T.s.dAi); },
        ask: (arg) => commands.ai(arg),
        date: () => `<span class="term__resp">${esc(new Date().toLocaleString(T.lang === 'en' ? 'en-GB' : 'it-IT'))}</span>`,
        echo: (arg) => `<span class="term__resp">${esc(arg || '')}</span>`,
        history: () => (history.length ? history.map((h, i) => `<span class="term__muted">${String(i + 1).padStart(3)}</span>  <span class="term__resp">${esc(h)}</span>`).join('\n') : '<span class="term__muted">—</span>'),
        sudo: () => `<span class="term__err">${esc(T.s.sudo)}</span>`,
        nmap: () => `<span class="term__resp">${esc(T.s.nmap)}</span>`,
        hack: () => `<span class="term__resp">${esc(T.s.hack)}</span>`,
      };

      // ---- finto filesystem: cat/less/more leggono; nano/vi/vim "aprono" (sola lettura) ----
      const files = {
        'focus.txt': () => commands.focus(),
        'cv.md': () => `<span class="term__key"># CV</span>\n<span class="term__resp">${esc(T.role)}</span>\n<span class="term__muted">→</span> ${link(T.paths.cv, T.paths.cv)}  <span class="term__muted">·</span>  ${link(T.cvpdf, 'cv.pdf ↓')}`,
        'skills.json': () =>
          '<span class="term__muted">{</span>\n' +
          T.focus.map(([k, d]) => `  <span class="term__key">"${k}"</span>: <span class="term__resp">"${esc(d)}"</span>`).join(',\n') +
          '\n<span class="term__muted">}</span>\n<span class="term__muted">→</span> ' + link(T.paths.skills, T.paths.skills),
        'about.md': () => `<span class="term__key"># whoami</span>\n<span class="term__resp">${esc(T.s.bio)}</span>\n<span class="term__muted">→</span> ${link(T.paths.about, T.paths.about)}`,
        'contact.md': () =>
          `<span class="term__key">email</span>     ${link('mailto:' + T.email, T.email)}\n` +
          Object.keys(T.links).map((k) => `<span class="term__key">${k.toLowerCase().padEnd(9)}</span> ${link(T.links[k], T.links[k])}`).join('\n'),
      };
      const dirs = { projects: T.paths.work, writings: T.paths.writing, writing: T.paths.writing, articles: T.paths.writing, blog: T.paths.writing };
      async function readFile(arg, editor) {
        const rawArg = (arg || '').trim();
        const raw = safeArg(rawArg);
        if (raw == null) return `<span class="term__err">cat: ${esc(rawArg)}: ${esc(T.s.badPath)}</span>`;
        if (!raw) return '<span class="term__err">usage: cat &lt;file&gt;</span> <span class="term__muted">— ls</span>';
        const bare = raw.replace(/\/$/, '');
        if (dirs[bare]) return `<span class="term__err">cat: ${esc(raw)}: ${esc(T.s.isDir)}</span>\n<span class="term__muted">→</span> ${link(dirs[bare], dirs[bare])}`;
        const parts = bare.split('/');
        const fileDirKey = parts.length === 1 && cwdKey !== 'root' ? cwdKey : parts.length === 2 ? dirKeyFromPath(parts[0]) : '';
        const filename = parts.length === 1 && cwdKey !== 'root' ? parts[0] : parts.length === 2 ? parts[1] : '';
        if (fileDirKey && filename) {
          const dir = await getDir(fileDirKey);
          const file = dir && dir.map[filename];
          if (!file) return `<span class="term__err">cat: ${esc(rawArg)}: ${esc(T.s.noFile)}</span>`;
          const content = `<span class="term__md">${esc(file.markdown)}</span>\n<span class="term__muted">→</span> ${link(file.href, file.href)}`;
          return editor ? content + `\n<span class="term__muted">${esc(T.s.readonly)}</span>` : content;
        }
        const f = files[raw] || files[bare];
        if (!f) return `<span class="term__err">cat: ${esc(raw)}: ${esc(T.s.noFile)}</span>`;
        const content = f();
        return editor ? content + `\n<span class="term__muted">${esc(T.s.readonly)}</span>` : content;
      }
      commands.cat = (a) => readFile(a, false);
      commands.less = (a) => readFile(a, false);
      commands.more = (a) => readFile(a, false);
      commands.nano = (a) => readFile(a, true);
      commands.vi = (a) => readFile(a, true);
      commands.vim = (a) => readFile(a, true);

      async function exec(raw) {
        const line = raw.trim();
        addLine(promptHtml() + `<span class="term__cmd">${esc(line)}</span>`);
        if (!line) return;
        history.push(line);
        hi = history.length;
        const sp = line.indexOf(' ');
        const name = (sp < 0 ? line : line.slice(0, sp)).toLowerCase();
        const arg = sp < 0 ? '' : line.slice(sp + 1).trim();
        if (name === 'clear' || name === 'cls') { log.innerHTML = ''; return; }
        const fn = commands[name];
        let out;
        try {
          out = fn ? await fn(arg) : `<span class="term__err">${esc(T.s.notFound)}: ${esc(name)}</span>\n<span class="term__muted">${esc(T.s.hint)}</span>`;
        } catch (_) {
          out = `<span class="term__err">${esc(T.s.loadError)}</span>`;
        }
        if (out != null) addLine(out, 'term__out');
      }
      const queueExec = (raw) => {
        commandQueue = commandQueue.then(() => exec(raw)).catch(() => {
          addLine(`<span class="term__err">${esc(T.s.loadError)}</span>`, 'term__out');
        });
      };

      // ---- input ----
      const caretEnd = () => requestAnimationFrame(() => { try { input.setSelectionRange(input.value.length, input.value.length); } catch (_) {} });
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          const v = input.value; input.value = '';
          queueExec(v);
          try { input.focus({ preventScroll: true }); } catch (_) {}
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (history.length) { hi = Math.max(0, hi - 1); input.value = history[hi] || ''; caretEnd(); }
        } else if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (history.length) { hi = Math.min(history.length, hi + 1); input.value = history[hi] || ''; caretEnd(); }
        } else if ((e.key === 'l' || e.key === 'L') && (e.ctrlKey || e.metaKey)) {
          e.preventDefault(); log.innerHTML = '';
        }
      });
      body.addEventListener('click', (e) => {
        if (e.target.closest('a')) return;
        if (e.target.closest('button')) return;
        if (window.getSelection && String(window.getSelection())) return;
        if (canAutoFocusInput() && !inputline.hidden) { try { input.focus({ preventScroll: true }); } catch (_) {} }
      });
      term.querySelectorAll('[data-term-action]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const action = btn.dataset.termAction;
          if (action === 'close' && shell) {
            try { input.blur(); } catch (_) {}
            setMaximized(false);
            shell.hidden = true;
          } else if (action === 'minimize') {
            setMinimized(true);
          } else if (action === 'maximize' && shell) {
            setMaximized(!shell.classList.contains('is-maximized'));
          }
        });
      });
      if (reopen) {
        reopen.addEventListener('click', () => {
          setMinimized(false);
          focusInput();
        });
      }

      // ---- intro typing (niente spazio pre-allocato: cresce mentre scrive) ----
      function typeCmd(text, done) {
        const lineEl = addLine(promptHtml() + '<span class="term__cmd"></span>');
        const span = lineEl.querySelector('.term__cmd');
        const caret = document.createElement('span');
        caret.className = 'term__caret';
        lineEl.appendChild(caret);
        let i = 0;
        (function tick() {
          span.textContent = text.slice(0, ++i);
          scroll();
          if (i < text.length) setTimeout(tick, 38 + Math.random() * 46);
          else { caret.remove(); setTimeout(done, 240); }
        })();
      }
      function finishIntro() {
        inputline.hidden = false;
        hi = history.length;
        scroll();
        focusInput();
      }
      // intro breve: digita whoami → output → hint → prompt vivo
      typeCmd('whoami', () => {
        addLine(commands.whoami(), 'term__out');
        history.push('whoami');
        setTimeout(() => {
          addLine(`<span class="term__muted"># ${T.s.introHint}</span>`, 'term__out');
          finishIntro();
        }, 220);
      });
    }

    if (!window.__termInit) { window.__termInit = true; document.addEventListener('astro:page-load', initTerms); }
    if (document.readyState !== 'loading') initTerms();
    else document.addEventListener('DOMContentLoaded', initTerms);
  })();
</script>
