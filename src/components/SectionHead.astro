---
interface Props { eyebrow?: string; title: string; accent?: string; sub?: string; align?: 'center' | 'left'; }
const { eyebrow, title, accent, sub } = Astro.props;
---
<div data-reveal class="field-heading">
  <div>{eyebrow && <p class="field-label">{eyebrow}</p>}</div>
  <div>
    <h2>{title}{accent && <> <span class="field-serif text-signal">{accent}</span></>}</h2>
    {sub && <p class="mt-5 max-w-xl text-base leading-relaxed text-muted">{sub}</p>}
  </div>
</div>
