---
import { getLangFromUrl, localizePath, stripLangPrefix } from '@/i18n/utils';
const lang = getLangFromUrl(Astro.url);
const normalizePath = (path: string) => {
  const clean = stripLangPrefix(path);
  return clean !== '/' ? clean.replace(/\/$/, '') : clean;
};
const base = normalizePath(Astro.url.pathname);
const alternatePaths: Record<string, { it: string; en: string }> = {
  '/404': { it: '/404', en: '/404' },
  '/certificati': { it: '/certificati', en: '/certifications' },
  '/certifications': { it: '/certificati', en: '/certifications' },
};
const mapped = alternatePaths[base] ?? { it: base, en: base };
const hrefs =
  base === '/404'
    ? { it: '/404', en: '/404' }
    : { it: localizePath(mapped.it, 'it'), en: localizePath(mapped.en, 'en') };
const opts = [
  { code: 'it', label: 'IT' },
  { code: 'en', label: 'EN' },
] as const;
---
<div class="inline-flex items-center rounded-md border border-ink-600 p-0.5 font-mono text-[11px]" role="group" aria-label="Language / Lingua">
  {opts.map((o) => (
    <a
      href={hrefs[o.code]}
      data-lang-link={o.code}
      aria-current={lang === o.code ? 'true' : undefined}
      class:list={[
        'rounded px-2 py-1 transition-colors',
        lang === o.code ? 'bg-accent text-ink-900' : 'text-muted hover:text-text',
      ]}
    >{o.label}</a>
  ))}
</div>

<script is:inline data-astro-rerun>
  document.querySelectorAll('[data-lang-link]').forEach((a) => {
    a.addEventListener('click', () => {
      try {
        const v = a.getAttribute('data-lang-link');
        localStorage.setItem('lang', v);
        document.cookie = 'lang=' + v + ';path=/;max-age=31536000;samesite=lax';
      } catch (e) {}
    });
  });
</script>
