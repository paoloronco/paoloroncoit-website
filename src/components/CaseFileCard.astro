---
import { categoryColors } from '@/data/site';
interface Props {
  href: string;
  title: string;
  summary: string;
  category: string;
  stack: string[];
  index?: number;
  variant?: 'default' | 'hybrid';
}
const { href, title, summary, category, stack, index, variant = 'default' } = Astro.props;
const color = categoryColors[category] ?? 'var(--color-accent)';
const num = index != null ? String(index).padStart(2, '0') : null;
---
<a
  href={href}
  style={`--cat:${color}`}
  class:list={[
    'readable-card',
    'group',
    'relative',
    'flex',
    'flex-col',
    'overflow-hidden',
    'rounded-card',
    'border',
    'border-ink-600',
    'bg-ink-800/75',
    'p-5',
    'shadow-2xl',
    'shadow-ink-900/25',
    'backdrop-blur-md',
    'transition-all',
    'hover:-translate-y-0.5',
    'hover:border-[var(--cat)]',
    'hover:bg-ink-800/95',
    variant === 'hybrid' ? 'casefile-card-hybrid' : '',
  ]}
>
  <!-- barra colore categoria -->
  <span class="absolute inset-x-0 top-0 h-0.5 opacity-80" style={`background:${color}`}></span>

  <div class="flex items-start justify-between gap-3">
    <span class="kicker rounded px-1.5 py-0.5" style={`color:${color};background:color-mix(in oklab, ${color} 14%, transparent)`}>{category}</span>
    {num && <span class="case-index text-3xl font-semibold">_{num}</span>}
  </div>

  <h3 class="readable-title mt-3 text-lg font-semibold text-text transition-colors group-hover:text-[var(--cat)]">{title}</h3>
  <p class="readable-summary mt-2 flex-1 text-sm leading-relaxed text-text-dim">{summary}</p>

  <div class="casefile-meta mt-4 flex flex-wrap items-center gap-1.5">
    {stack.map((s) => (
      <span class="rounded border border-ink-600 px-1.5 py-0.5 font-mono text-[10px] text-muted transition-colors group-hover:text-text-dim">{s}</span>
    ))}
    <span class="case-arrow ml-auto font-mono text-sm text-[var(--cat)]" aria-hidden="true">↗</span>
  </div>
</a>

<style>
  :global(html:not([data-readable-mode='true']) .casefile-card-hybrid) {
    padding: 1.45rem;
    min-height: 255px;
    background: color-mix(in oklab, var(--color-ink-800) 85%, transparent);
    box-shadow: 0 18px 40px -34px color-mix(in oklab, var(--color-ink-900) 70%, black);
  }

  :global(html:not([data-readable-mode='true']) .casefile-card-hybrid:hover) {
    background: color-mix(in oklab, var(--color-ink-800) 92%, transparent);
  }

  :global(html:not([data-readable-mode='true']) .casefile-card-hybrid .readable-title) {
    font-size: 1.12rem;
    line-height: 1.38;
    margin-top: 0.9rem;
  }

  :global(html:not([data-readable-mode='true']) .casefile-card-hybrid .readable-summary) {
    font-size: 0.94rem;
    line-height: 1.72;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 6.6rem;
  }

  :global(html:not([data-readable-mode='true']) .casefile-card-hybrid .casefile-meta) {
    margin-top: auto;
  }
</style>
