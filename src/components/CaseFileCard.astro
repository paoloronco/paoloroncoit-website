---
import { categoryColors } from '@/data/site';
interface Props {
  href: string;
  title: string;
  summary: string;
  category: string;
  stack: string[];
  index?: number;
}
const { href, title, summary, category, stack, index } = Astro.props;
const color = categoryColors[category] ?? 'var(--color-accent)';
const num = index != null ? String(index).padStart(2, '0') : null;
---
<a
  href={href}
  style={`--cat:${color}`}
  class="group relative flex flex-col overflow-hidden rounded-card border border-ink-600 bg-ink-800/50 p-5 transition-all hover:-translate-y-0.5 hover:border-[var(--cat)] hover:bg-ink-800"
>
  <!-- barra colore categoria -->
  <span class="absolute inset-x-0 top-0 h-0.5 opacity-80" style={`background:${color}`}></span>

  <div class="flex items-start justify-between gap-3">
    <span class="kicker rounded px-1.5 py-0.5" style={`color:${color};background:color-mix(in oklab, ${color} 14%, transparent)`}>{category}</span>
    {num && <span class="case-index text-3xl font-semibold">_{num}</span>}
  </div>

  <h3 class="mt-3 text-lg font-semibold text-text transition-colors group-hover:text-[var(--cat)]">{title}</h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-text-dim">{summary}</p>

  <div class="mt-4 flex flex-wrap items-center gap-1.5">
    {stack.map((s) => (
      <span class="rounded border border-ink-600 px-1.5 py-0.5 font-mono text-[10px] text-muted transition-colors group-hover:text-text-dim">{s}</span>
    ))}
    <span class="case-arrow ml-auto font-mono text-sm text-[var(--cat)]" aria-hidden="true">↗</span>
  </div>
</a>
