---
interface Props { href: string; title: string; summary: string; category: string; stack: string[]; index?: number; }
const { href, title, summary, category, stack, index } = Astro.props;
const num = String(index ?? 1).padStart(2, '0');
---
<a href={href} class="dossier-row group">
  <span class="dossier-row__index">{num}</span>
  <h3 class="dossier-row__title">{title}</h3>
  <p class="dossier-row__summary">{summary}</p>
  <p class="dossier-row__meta">{category}<br />{stack.slice(0, 3).join(' / ')}</p>
  <span class="text-xl" aria-hidden="true">↗</span>
</a>
