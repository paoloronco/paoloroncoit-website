---
import { site, nav } from '@/data/site';
import LanguageSelector from '@/components/LanguageSelector.astro';
import { getLangFromUrl, useTranslations, localizePath, stripLangPrefix } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const current = stripLangPrefix(Astro.url.pathname);
const isActive = (href: string) => current === href || current.startsWith(href + '/');
// Label di menu localizzate.
const navLabel = (href: string) => t(`nav.${href.replace(/\//g, '')}` as any);
---

<header class="sticky top-0 z-30 border-b border-ink-600/70 bg-ink-900/80 backdrop-blur-md">
  <div class="mx-auto flex h-14 max-w-5xl items-center gap-5 px-5">
    <a href={localizePath('/', lang)} class="font-mono text-sm font-semibold tracking-tight text-text hover:text-accent">
      {site.name.toUpperCase()}
    </a>

    <nav class="hidden items-center gap-5 text-sm sm:flex" aria-label="Principale">
      {nav.map((item) => (
        <a
          href={localizePath(item.href, lang)}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class:list={[
            'transition-colors hover:text-text',
            isActive(item.href) ? 'text-text' : 'text-muted',
          ]}
        >
          {navLabel(item.href)}
        </a>
      ))}
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <div class="hidden sm:block">
        <LanguageSelector />
      </div>
      <button
        type="button"
        data-cmdk-open
        class="group flex items-center gap-2 rounded-full border border-ink-500 bg-ink-800/60 py-1.5 pl-3 pr-1.5 text-xs text-muted transition-all hover:border-accent/70 hover:text-text hover:shadow-md hover:shadow-accent/10"
        aria-label={t('header.openPalette')}
        title={t('header.openPalette')}
      >
        <svg class="h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4.3-4.3"></path>
        </svg>
        <span class="hidden whitespace-nowrap sm:inline">{t('header.search')}</span>
        <span class="ml-0.5 inline-flex shrink-0 items-center gap-1 rounded-full bg-accent/15 px-1.5 py-0.5 text-accent">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l1.7 5.6L19 9l-5.3 1.4L12 16l-1.7-5.6L5 9l5.3-1.4L12 2z"></path>
            <path d="M19 14l.8 2.4L22 17l-2.2.6L19 20l-.8-2.4L16 17l2.2-.6L19 14z" opacity="0.7"></path>
          </svg>
          <span class="font-mono text-[10px] font-semibold tracking-wide">AI</span>
        </span>
      </button>

      <!-- Hamburger (solo mobile) -->
      <button
        type="button"
        data-mobile-toggle
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Menu"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-ink-500 bg-ink-700 text-text transition-colors hover:border-accent sm:hidden"
      >
        <svg data-icon-open width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
        <svg data-icon-close class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>
  </div>

  <!-- Pannello nav mobile -->
  <nav
    id="mobile-nav"
    data-mobile-nav
    data-state="closed"
    class="mobile-nav bg-ink-900/95 backdrop-blur-md sm:hidden"
    aria-label="Menu mobile"
    aria-hidden="true"
    inert
  >
    <div class="mobile-nav__clip">
      <div class="mobile-nav__inner">
        {nav.map((item) => (
          <a
            href={localizePath(item.href, lang)}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'block rounded-md px-3 py-3 text-base transition-colors',
              isActive(item.href) ? 'bg-ink-700 text-text' : 'text-text-dim hover:bg-ink-800 hover:text-text',
            ]}
          >
            {navLabel(item.href)}
          </a>
        ))}
        <div class="mt-3 flex items-center justify-between border-t border-ink-600/70 px-3 pt-4">
          <span class="font-mono text-[11px] uppercase tracking-wide text-muted/70">Lingua / Language</span>
          <LanguageSelector />
        </div>
      </div>
    </div>
  </nav>
</header>

<script is:inline data-astro-rerun>
  (() => {
    const btn = document.querySelector('[data-mobile-toggle]');
    const panel = document.querySelector('[data-mobile-nav]');
    if (!btn || !panel) return;
    const open = btn.querySelector('[data-icon-open]');
    const close = btn.querySelector('[data-icon-close]');
    const setOpen = (v) => {
      panel.dataset.state = v ? 'open' : 'closed';
      panel.setAttribute('aria-hidden', v ? 'false' : 'true');
      if ('inert' in panel) panel.inert = !v;
      btn.setAttribute('aria-expanded', v ? 'true' : 'false');
      open && open.classList.toggle('hidden', v);
      close && close.classList.toggle('hidden', !v);
    };
    setOpen(false);
    btn.addEventListener('click', () => setOpen(panel.dataset.state !== 'open'));
    // chiude toccando un link (la navigazione avviene comunque)
    panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && panel.dataset.state === 'open') setOpen(false);
    });
  })();
</script>
