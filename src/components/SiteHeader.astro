---
import { site, nav } from '@/data/site';
import LanguageSelector from '@/components/LanguageSelector.astro';
import { getLangFromUrl, useTranslations, localizePath, stripLangPrefix } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const current = stripLangPrefix(Astro.url.pathname);
const isActive = (href: string) => current === href || current.startsWith(href + '/');
---

<header class="sticky top-0 z-30 border-b border-ink-600/70 bg-ink-900/80 backdrop-blur-md">
  <div class="mx-auto flex h-14 max-w-5xl items-center gap-5 px-5">
    <a href={localizePath('/', lang)} class="font-mono text-sm font-semibold tracking-tight text-text hover:text-accent">
      {site.name.toUpperCase()}
    </a>

    <nav class="hidden items-center gap-5 text-sm sm:flex" aria-label="Principale">
      {nav.map((item) => (
        <a
          href={localizePath(item.href, lang)}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class:list={[
            'transition-colors hover:text-text',
            isActive(item.href) ? 'text-text' : 'text-muted',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <LanguageSelector />
      <button
        type="button"
        data-cmdk-open
        class="group inline-flex items-center gap-2 rounded-full border border-ink-500 bg-ink-800/60 py-1.5 pl-2.5 pr-3.5 text-xs text-muted transition-all hover:-translate-y-px hover:border-accent/70 hover:text-text hover:shadow-md hover:shadow-accent/10"
        aria-label={t('header.openPalette')}
      >
        <svg class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4.3-4.3"></path>
        </svg>
        <span class="hidden sm:inline">{t('header.search')}</span>
      </button>

      <!-- Hamburger (solo mobile) -->
      <button
        type="button"
        data-mobile-toggle
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Menu"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-ink-500 bg-ink-700 text-text transition-colors hover:border-accent sm:hidden"
      >
        <svg data-icon-open width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
        <svg data-icon-close class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>
  </div>

  <!-- Pannello nav mobile -->
  <nav
    id="mobile-nav"
    data-mobile-nav
    class="hidden border-t border-ink-600/70 bg-ink-900/95 px-5 py-3 backdrop-blur-md sm:hidden"
    aria-label="Menu mobile"
  >
    {nav.map((item) => (
      <a
        href={localizePath(item.href, lang)}
        aria-current={isActive(item.href) ? 'page' : undefined}
        class:list={[
          'block rounded-md px-3 py-3 text-base transition-colors',
          isActive(item.href) ? 'bg-ink-700 text-text' : 'text-text-dim hover:bg-ink-800 hover:text-text',
        ]}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script is:inline data-astro-rerun>
  (() => {
    const btn = document.querySelector('[data-mobile-toggle]');
    const panel = document.querySelector('[data-mobile-nav]');
    if (!btn || !panel) return;
    const open = btn.querySelector('[data-icon-open]');
    const close = btn.querySelector('[data-icon-close]');
    const setOpen = (v) => {
      panel.classList.toggle('hidden', !v);
      btn.setAttribute('aria-expanded', v ? 'true' : 'false');
      open && open.classList.toggle('hidden', v);
      close && close.classList.toggle('hidden', !v);
    };
    btn.addEventListener('click', () => setOpen(panel.classList.contains('hidden')));
    // chiude toccando un link (la navigazione avviene comunque)
    panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
  })();
</script>
