---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import CommandPalette from '@/components/CommandPalette.astro';
import ChatWidget from '@/components/ChatWidget.astro';
import Motion from '@/components/Motion.astro';
import Analytics from '@/components/Analytics.astro';
import { site } from '@/data/site';
import { getLangFromUrl, localizePath, stripLangPrefix } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';

interface Props {
  title?: string;
  description?: string;
  /** Path canonico IT, es. "/writing" (senza prefisso lingua). */
  path?: string;
}

const { title, description = site.description, path = '' } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = stripLangPrefix(path || Astro.url.pathname);

const fullTitle = title ? `${title} — ${site.name}` : `${site.name} · ${site.role}`;
const origin = Astro.site ?? new URL(site.url);
const canonical = new URL(localizePath(base, lang), origin).toString();
const altIt = new URL(localizePath(base, 'it'), origin).toString();
const altEn = new URL(localizePath(base, 'en'), origin).toString();

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: site.role,
  url: site.url,
  email: `mailto:${site.email}`,
  sameAs: Object.values(site.socials),
  knowsAbout: site.domains,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Analytics />
    <script is:inline>document.documentElement.classList.add('motion');</script>
    <script is:inline>
      try {
        document.documentElement.setAttribute('data-readable-mode', localStorage.getItem('readableMode') === 'true' ? 'true' : 'false');
      } catch (e) {}
    </script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="it" href={altIt} />
    <link rel="alternate" hreflang="en" href={altEn} />
    <link rel="alternate" hreflang="x-default" href={altEn} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <ClientRouter />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'it_IT'} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="alternate" type="application/rss+xml" title={site.name} href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#0a0c12" />

    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />

    <!-- Auto-rilevamento lingua: scelta manuale > browser/dispositivo. IT resta su "/", tutto il resto va su "/en/". -->
    <script is:inline>
      (function () {
        try {
          var p = location.pathname;
          var current = p === '/en' || p === '/en/' || p.indexOf('/en/') === 0 ? 'en' : 'it';

          function alt(path, lang) {
            var clean = path;
            if (path === '/en' || path === '/en/') clean = '/';
            else if (path.indexOf('/en/') === 0) clean = path.slice(3);
            if (lang === 'it') return clean;
            return clean === '/' ? '/en/' : '/en' + clean;
          }

          function cookieLang() {
            var match = document.cookie.match(/(?:^|;\s*)lang=(it|en)(?:;|$)/);
            return match ? match[1] : null;
          }

          function browserLang() {
            var langs = navigator.languages && navigator.languages.length ? navigator.languages : [navigator.language || 'en'];
            for (var i = 0; i < langs.length; i++) {
              if ((langs[i] || '').toLowerCase().split('-')[0] === 'it') return 'it';
            }
            return 'en';
          }

          var stored = localStorage.getItem('lang');
          var target = stored === 'it' || stored === 'en' ? stored : cookieLang() || browserLang();

          if (target && target !== current) {
            location.replace(alt(p, target) + location.search + location.hash);
          }
        } catch (e) {}
      })();
    </script>

    <!-- Evita che mobile apra la tastiera per focus ripristinati o auto-focus involontari al caricamento. -->
    <script is:inline>
      (function () {
        function hasTouchInput() {
          return (
            (navigator.maxTouchPoints || 0) > 0 ||
            (navigator.msMaxTouchPoints || 0) > 0 ||
            (window.matchMedia && window.matchMedia('(pointer: coarse)').matches)
          );
        }

        function blurMobileTextInput() {
          if (!hasTouchInput()) return;
          var el = document.activeElement;
          if (!el || !el.matches) return;
          if (el.matches('[data-term-input], [data-chatw-input], [data-ask-input], input[type="text"], textarea')) {
            try { el.blur(); } catch (e) {}
          }
        }

        function scheduleBlur() {
          blurMobileTextInput();
          setTimeout(blurMobileTextInput, 0);
          setTimeout(blurMobileTextInput, 250);
        }

        document.addEventListener('DOMContentLoaded', scheduleBlur);
        document.addEventListener('astro:page-load', scheduleBlur);
        window.addEventListener('pageshow', scheduleBlur);
      })();
    </script>

    <!-- Easter egg per i peer che aprono la console -->
    <script is:inline>
      console.log(
        '%c↳ curioso? il sorgente è su github.com/paoloronco — security.txt in /.well-known/',
        'color:#4f8dff;font-family:monospace;font-size:12px'
      );
    </script>
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:m-3 focus:rounded focus:bg-accent focus:px-3 focus:py-2 focus:text-ink-900">
      {t('a11y.skip')}
    </a>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
    <CommandPalette />
    <ChatWidget />
    <Motion />
  </body>
</html>
