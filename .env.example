# Assistente AI — il proxy /api/ask inoltra a n8n tenendo il token lato server.
# Imposta queste variabili anche su Vercel → Settings → Environment Variables.
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/wp-ai-chatbot
N8N_AUTH_HEADER_NAME=Authorization
N8N_AUTH_HEADER_VALUE=Bearer your-token-here
SITE_HOME_URL=https://paoloronco.it/
