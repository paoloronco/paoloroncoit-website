# Assistente AI — il proxy /api/ask inoltra a n8n tenendo il token lato server.
# Imposta queste variabili anche su Vercel → Settings → Environment Variables.
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/paoloroncoit-chatbot
N8N_AUTH_HEADER_NAME=Authorization
N8N_AUTH_HEADER_VALUE=Bearer your-token-here
SITE_HOME_URL=https://paoloronco.it/

# Public analytics identifiers. Configure the same variables in Vercel.
# These values are public IDs, not secrets. A new deployment is required after changes.
PUBLIC_COOKIEYES_ID=your-cookieyes-client-id
PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
PUBLIC_MICROSOFT_CLARITY_ID=your-clarity-project-id
